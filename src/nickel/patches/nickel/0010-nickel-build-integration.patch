From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2026 00:00:00 +0000
Subject: [PATCH 10/10] nickel: build-integration — wire Nickel components into BUILD.gn

---
 chrome/browser/BUILD.gn | 5 +++++
 chrome/renderer/BUILD.gn | 5 +++++
 2 files changed, 10 insertions(+)

diff --git a/chrome/browser/BUILD.gn b/chrome/browser/BUILD.gn
index aabbccdd..eeff0011 100644
--- a/chrome/browser/BUILD.gn
+++ b/chrome/browser/BUILD.gn
@@ -100,6 +100,11 @@ static_library("browser") {
     "//chrome/browser/ui",
     "//chrome/common",
+    "//src/nickel:nickel_browser",
   ]
 }

diff --git a/chrome/renderer/BUILD.gn b/chrome/renderer/BUILD.gn
index aabbccdd..eeff0011 100644
--- a/chrome/renderer/BUILD.gn
+++ b/chrome/renderer/BUILD.gn
@@ -50,6 +50,11 @@ static_library("renderer") {
   deps = [
     "//chrome/common",
+    "//src/nickel:nickel_renderer",
   ]
 }
