From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2026 00:00:00 +0000
Subject: [PATCH 02/10] nickel: user-agent — custom Nickel product token

---
 components/embedder_support/user_agent_utils.cc | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/components/embedder_support/user_agent_utils.cc b/components/embedder_support/user_agent_utils.cc
index aabbccdd..eeff0011 100644
--- a/components/embedder_support/user_agent_utils.cc
+++ b/components/embedder_support/user_agent_utils.cc
@@ -5,6 +5,10 @@
 #include "components/embedder_support/user_agent_utils.h"
+#include "chrome/browser/nickel/nickel_version.h"
 
 std::string BuildUserAgentFromProduct(const std::string& product) {
+  std::string nickel_product = product + " NickelBrowser/" + nickel::GetNickelVersion();
+  return nickel_product;
 }
