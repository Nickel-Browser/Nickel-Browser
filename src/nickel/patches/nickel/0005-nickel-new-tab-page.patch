+/* Copyright (c) 2026 Nickel Browser Project */
+/* nickel_ntp.css — Nickel Browser new-tab page styles */
+
+:root {
+  --nickel-primary:   #FF4500;
+  --nickel-bg:        #1a1a2e;
+  --nickel-surface:   #16213e;
+  --nickel-text:      #e0e0e0;
+  --nickel-accent:    #00d4aa;
+  --nickel-muted:     rgba(255,255,255,0.5);
+}
+
+*, *::before, *::after { box-sizing: border-box; }
+
+body {
+  margin: 0;
+  background: var(--nickel-bg);
+  color: var(--nickel-text);
+  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
+}
+
+.sr-only {
+  position: absolute; width: 1px; height: 1px;
+  padding: 0; margin: -1px; overflow: hidden;
+  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
+}
+
+.ntp-container {
+  max-width: 680px;
+  margin: 0 auto;
+  padding: 60px 24px 40px;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 40px;
+}
+
+.ntp-header { text-align: center; }
+.ntp-title  { font-size: 2.2rem; font-weight: 700; margin: 12px 0 4px; }
+.ntp-subtitle { color: var(--nickel-muted); font-size: 1rem; margin: 0; }
+
+.ntp-search { width: 100%; }
+.search-input-wrapper {
+  display: flex;
+  background: var(--nickel-surface);
+  border: 1px solid rgba(255,255,255,0.1);
+  border-radius: 28px;
+  overflow: hidden;
+  transition: border-color 0.2s;
+}
+.search-input-wrapper:focus-within { border-color: var(--nickel-accent); }
+
+#search-input {
+  flex: 1;
+  background: transparent;
+  border: none;
+  padding: 14px 20px;
+  color: var(--nickel-text);
+  font-size: 1rem;
+  outline: none;
+}
+#search-input::placeholder { color: var(--nickel-muted); }
+
+.search-input-wrapper button {
+  background: transparent;
+  border: none;
+  padding: 0 20px;
+  color: var(--nickel-muted);
+  cursor: pointer;
+  display: flex;
+  align-items: center;
+  transition: color 0.2s;
+}
+.search-input-wrapper button:hover { color: var(--nickel-accent); }
+
+.ntp-stats {
+  display: flex;
+  gap: 20px;
+  width: 100%;
+  justify-content: center;
+}
+.stat-card {
+  background: var(--nickel-surface);
+  border-radius: 12px;
+  padding: 20px 24px;
+  text-align: center;
+  flex: 1;
+}
+.stat-number { display: block; font-size: 2rem; font-weight: 700; color: var(--nickel-accent); }
+.stat-label  { font-size: 0.8rem; color: var(--nickel-muted); margin-top: 4px; display: block; }
+
+.ntp-actions { display: flex; gap: 16px; }
+.action-btn {
+  background: var(--nickel-surface);
+  border: 1px solid rgba(255,255,255,0.1);
+  border-radius: 8px;
+  color: var(--nickel-text);
+  cursor: pointer;
+  font-size: 0.95rem;
+  padding: 10px 20px;
+  transition: background 0.2s, border-color 0.2s;
+}
+.action-btn:hover {
+  background: var(--nickel-primary);
+  border-color: var(--nickel-primary);
+  color: #fff;
+}
