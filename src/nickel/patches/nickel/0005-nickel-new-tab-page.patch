+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_ntp_handler.cc
+// WebUI message handler for the Nickel new-tab page.
+
+#include "chrome/browser/nickel/ntp/nickel_ntp_handler.h"
+
+#include "base/bind.h"
+#include "base/values.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace nickel {
+namespace ntp {
+
+NickelNTPHandler::NickelNTPHandler() = default;
+NickelNTPHandler::~NickelNTPHandler() = default;
+
+void NickelNTPHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getPrivacyStats",
+      base::BindRepeating(&NickelNTPHandler::HandleGetPrivacyStats,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "openSettings",
+      base::BindRepeating(&NickelNTPHandler::HandleOpenSettings,
+                          base::Unretained(this)));
+}
+
+void NickelNTPHandler::HandleGetPrivacyStats(
+    const base::Value::List& args) {
+  Profile* profile = Profile::FromWebUI(web_ui());
+  PrefService* prefs = profile->GetPrefs();
+
+  base::Value::Dict stats;
+  stats.Set("adsBlocked",
+            prefs->GetInteger("nickel.adblock.ads_blocked_today"));
+  stats.Set("trackersBlocked",
+            prefs->GetInteger("nickel.adblock.trackers_blocked_today"));
+  stats.Set("fingerprintAttempts",
+            prefs->GetInteger("nickel.fingerprint.blocked_today"));
+  stats.Set("adblockEnabled",
+            prefs->GetBoolean("nickel.adblock.enabled"));
+  stats.Set("fingerprintEnabled",
+            prefs->GetBoolean("nickel.fingerprint.enabled"));
+  stats.Set("torEnabled",
+            prefs->GetBoolean("nickel.tor.enabled"));
+
+  AllowJavascript();
+  if (args.size() > 0 && args[0].is_string()) {
+    ResolveJavascriptCallback(args[0], std::move(stats));
+  }
+}
+
+void NickelNTPHandler::HandleOpenSettings(
+    const base::Value::List& /*args*/) {
+  web_ui()->GetWebContents()->GetController().LoadURL(
+      GURL("chrome://settings/privacy"),
+      content::Referrer(),
+      ui::PAGE_TRANSITION_AUTO_TOPLEVEL,
+      std::string());
+}
+
+}  // namespace ntp
+}  // namespace nickel
