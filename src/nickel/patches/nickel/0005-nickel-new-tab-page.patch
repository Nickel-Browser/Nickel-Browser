+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_ntp_handler.h
+
+#ifndef CHROME_BROWSER_NICKEL_NTP_NICKEL_NTP_HANDLER_H_
+#define CHROME_BROWSER_NICKEL_NTP_NICKEL_NTP_HANDLER_H_
+
+#include "base/values.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace nickel {
+namespace ntp {
+
+// WebUI message handler for chrome://nickel-newtab.
+// Provides privacy statistics and quick-action callbacks to the NTP JS.
+class NickelNTPHandler : public content::WebUIMessageHandler {
+ public:
+  NickelNTPHandler();
+  ~NickelNTPHandler() override;
+
+  NickelNTPHandler(const NickelNTPHandler&) = delete;
+  NickelNTPHandler& operator=(const NickelNTPHandler&) = delete;
+
+  // WebUIMessageHandler:
+  void RegisterMessages() override;
+
+ private:
+  // Sends today's ad-block / fingerprint stats to the NTP JS.
+  void HandleGetPrivacyStats(const base::Value::List& args);
+
+  // Navigates to chrome://settings/privacy.
+  void HandleOpenSettings(const base::Value::List& args);
+};
+
+}  // namespace ntp
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_NTP_NICKEL_NTP_HANDLER_H_
