new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/chrome/browser/resources/nickel_ntp/nickel_ntp.js
@@ -0,0 +1,72 @@
+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_ntp.js — Nickel Browser new-tab page script.
+// Communicates with NickelNTPHandler via chrome.send / cr.sendWithPromise.
+
+'use strict';
+
+(function() {
+
+/**
+ * Request privacy stats from the browser and update the stat cards.
+ */
+function loadPrivacyStats() {
+  // cr.sendWithPromise is the standard Chrome WebUI IPC mechanism.
+  if (typeof cr !== 'undefined' && cr.sendWithPromise) {
+    cr.sendWithPromise('getPrivacyStats')
+      .then(function(stats) {
+        updateStatCard('ads-blocked',         stats.adsBlocked);
+        updateStatCard('trackers-blocked',     stats.trackersBlocked);
+        updateStatCard('fingerprint-blocked',  stats.fingerprintAttempts);
+      })
+      .catch(function(err) {
+        console.warn('Nickel NTP: could not load stats:', err);
+      });
+  } else {
+    // Fallback when running outside the browser (e.g., during development).
+    updateStatCard('ads-blocked',        0);
+    updateStatCard('trackers-blocked',   0);
+    updateStatCard('fingerprint-blocked',0);
+  }
+}
+
+/**
+ * Update a stat card's number display.
+ * @param {string} id - Element id.
+ * @param {number} value - Stat value.
+ */
+function updateStatCard(id, value) {
+  var el = document.getElementById(id);
+  if (el) {
+    el.textContent = (typeof value === 'number') ? value.toLocaleString() : '0';
+  }
+}
+
+/**
+ * Wire up quick-action buttons.
+ */
+function initButtons() {
+  var settingsBtn = document.getElementById('btn-settings');
+  if (settingsBtn) {
+    settingsBtn.addEventListener('click', function() {
+      if (typeof chrome !== 'undefined' && chrome.send) {
+        chrome.send('openSettings');
+      } else {
+        window.location.href = 'chrome://settings/privacy';
+      }
+    });
+  }
+
+  var torBtn = document.getElementById('btn-tor');
+  if (torBtn) {
+    torBtn.addEventListener('click', function() {
+      // Opens a new Tor private tab. Handled by NickelTorController.
+      if (typeof chrome !== 'undefined' && chrome.send) {
+        chrome.send('openTorTab');
+      }
+    });
+  }
+}
+
+document.addEventListener('DOMContentLoaded', function() {
+  loadPrivacyStats();
+  initButtons();
+});
+
+})();
