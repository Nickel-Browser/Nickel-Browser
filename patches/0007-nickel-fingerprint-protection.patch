diff --git a/third_party/blink/renderer/modules/nickel_fingerprint/nickel_fingerprint_noise.cc b/third_party/blink/renderer/modules/nickel_fingerprint/nickel_fingerprint_noise.cc
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/third_party/blink/renderer/modules/nickel_fingerprint/nickel_fingerprint_noise.cc
@@ -0,0 +1,96 @@
+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+
+#include "third_party/blink/renderer/modules/nickel_fingerprint/nickel_fingerprint_noise.h"
+
+#include <algorithm>
+#include <atomic>
+#include <mutex>
+
+#include "base/rand_util.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+
+namespace blink::nickel_fingerprint {
+
+namespace {
+
+std::atomic<uint64_t> g_seed{0};
+std::once_flag g_seed_once;
+
+uint64_t InitSeed() {
+  uint64_t seed = base::RandUint64();
+  g_seed.store(seed, std::memory_order_relaxed);
+  return seed;
+}
+
+}  // namespace
+
+bool NickelFingerprintNoise::Enabled() {
+  return true;
+}
+
+uint64_t NickelFingerprintNoise::SessionSeed() {
+  std::call_once(g_seed_once, InitSeed);
+  return g_seed.load(std::memory_order_relaxed);
+}
+
+void NickelFingerprintNoise::ApplyCanvasNoise(uint8_t* data, size_t length) {
+  if (!Enabled() || !data || length == 0) {
+    return;
+  }
+  const uint64_t seed = SessionSeed();
+  for (size_t i = 0; i < length; ++i) {
+    const uint8_t delta = static_cast<uint8_t>((seed + i) % 3);
+    data[i] = static_cast<uint8_t>(std::min(255, data[i] + delta));
+  }
+}
+
+float NickelFingerprintNoise::AudioNoise() {
+  if (!Enabled()) {
+    return 0.0f;
+  }
+  const uint64_t seed = SessionSeed();
+  return static_cast<float>((seed % 5) - 2) * 1e-5f;
+}
+
+const String& NickelFingerprintNoise::SpoofedWebGLVendor() {
+  DEFINE_STATIC_LOCAL(String, kVendor, ("Google Inc."));
+  return kVendor;
+}
+
+const String& NickelFingerprintNoise::SpoofedWebGLRenderer() {
+  DEFINE_STATIC_LOCAL(
+      String, kRenderer,
+      ("ANGLE (Google, Vulkan 1.3.0 (SwiftShader Device (LLVM 10.0.0)))"));
+  return kRenderer;
+}
+
+}  // namespace blink::nickel_fingerprint

