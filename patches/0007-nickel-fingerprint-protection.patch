+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_fingerprint_service.h
+// Browser-process service that generates and manages per-profile
+// fingerprint noise seeds.
+
+#ifndef CHROME_BROWSER_NICKEL_FINGERPRINT_NICKEL_FINGERPRINT_SERVICE_H_
+#define CHROME_BROWSER_NICKEL_FINGERPRINT_NICKEL_FINGERPRINT_SERVICE_H_
+
+#include <cstdint>
+#include <string>
+
+#include "components/keyed_service/core/keyed_service.h"
+
+class Profile;
+
+namespace nickel {
+
+// KeyedService attached to each Profile.
+// Generates a stable, per-profile seed used to noise fingerprinting APIs.
+class NickelFingerprintService : public KeyedService {
+ public:
+  explicit NickelFingerprintService(Profile* profile);
+  ~NickelFingerprintService() override;
+
+  NickelFingerprintService(const NickelFingerprintService&) = delete;
+  NickelFingerprintService& operator=(const NickelFingerprintService&) = delete;
+
+  // Returns the 64-bit noise seed for this profile session.
+  // The seed is regenerated each browser restart to prevent persistent
+  // fingerprinting.
+  uint64_t GetNoiseSeed() const;
+
+  // True when fingerprint protection is enabled for this profile.
+  bool IsEnabled() const;
+  void SetEnabled(bool enabled);
+
+ private:
+  uint64_t noise_seed_ = 0;
+  bool enabled_ = true;
+  Profile* profile_;  // not owned
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_FINGERPRINT_NICKEL_FINGERPRINT_SERVICE_H_
