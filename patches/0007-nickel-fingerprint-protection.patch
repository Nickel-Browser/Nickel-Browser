+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_fingerprint_service.cc
+
+#include "chrome/browser/nickel/fingerprint/nickel_fingerprint_service.h"
+
+#include "base/rand_util.h"
+#include "chrome/browser/profiles/profile.h"
+#include "components/prefs/pref_service.h"
+
+namespace nickel {
+
+NickelFingerprintService::NickelFingerprintService(Profile* profile)
+    : profile_(profile) {
+  DCHECK(profile_);
+
+  // Load the per-profile seed from prefs.  If none exists yet (first run),
+  // generate a fresh random seed.
+  PrefService* prefs = profile_->GetPrefs();
+  if (!prefs) {
+    noise_seed_ = base::RandUint64();
+    return;
+  }
+
+  enabled_ = prefs->GetBoolean("nickel.fingerprint.enabled");
+
+  // Regenerate the seed each browser session for maximum privacy.
+  // A per-session seed means the site always sees the *same* noised value
+  // within a single session (so pages that read the value twice don't detect
+  // inconsistency), but get a different value next launch.
+  noise_seed_ = base::RandUint64();
+
+  // Persist seed until next restart (it's overwritten on next startup).
+  // We intentionally do NOT persist it across restarts.
+}
+
+NickelFingerprintService::~NickelFingerprintService() = default;
+
+uint64_t NickelFingerprintService::GetNoiseSeed() const {
+  return noise_seed_;
+}
+
+bool NickelFingerprintService::IsEnabled() const {
+  return enabled_;
+}
+
+void NickelFingerprintService::SetEnabled(bool enabled) {
+  enabled_ = enabled;
+  if (profile_ && profile_->GetPrefs()) {
+    profile_->GetPrefs()->SetBoolean("nickel.fingerprint.enabled", enabled);
+  }
+}
+
+}  // namespace nickel
