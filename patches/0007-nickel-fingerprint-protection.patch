@@ -0,0 +1,102 @@
+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_fingerprint_shield.cc
+
+#include "chrome/renderer/nickel/nickel_fingerprint_shield.h"
+
+#include "base/logging.h"
+#include "base/strings/string_number_conversions.h"
+#include "content/public/renderer/render_frame.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "v8/include/v8.h"
+
+namespace nickel {
+
+NickelFingerprintShield::NickelFingerprintShield(
+    content::RenderFrame* render_frame,
+    uint64_t noise_seed)
+    : content::RenderFrameObserver(render_frame),
+      noise_seed_(noise_seed) {}
+
+NickelFingerprintShield::~NickelFingerprintShield() = default;
+
+void NickelFingerprintShield::DidCreateScriptContext(
+    v8::Local<v8::Context> context,
+    int32_t world_id) {
+  if (world_id != 0) return;  // main world only
+  InjectFingerprintShims(context);
+}
+
+void NickelFingerprintShield::OnDestruct() {
+  delete this;
+}
+
+void NickelFingerprintShield::InjectFingerprintShims(
+    v8::Local<v8::Context> context) {
+  v8::Isolate* isolate = context->GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Context::Scope context_scope(context);
+
+  // Build a tiny JS shim that wraps Canvas / AudioContext / Navigator APIs.
+  // The noise_seed is injected as a constant so the shim is deterministic
+  // within a session.
+  const std::string seed_str = base::NumberToString(noise_seed_);
+
+  // language=JavaScript
+  const std::string shim = R"JS(
+(function(seed) {
+  'use strict';
+
+  // --- Canvas noise ---
+  const origToDataURL = HTMLCanvasElement.prototype.toDataURL;
+  const origGetImageData = CanvasRenderingContext2D.prototype.getImageData;
+
+  function seededRandom(n) {
+    // xorshift32 with the session seed
+    n ^= (n << 13); n ^= (n >> 17); n ^= (n << 5);
+    return (n >>> 0) / 0xFFFFFFFF;
+  }
+
+  CanvasRenderingContext2D.prototype.getImageData = function(x, y, w, h) {
+    const data = origGetImageData.call(this, x, y, w, h);
+    for (let i = 0; i < data.data.length; i += 4) {
+      const noise = Math.round((seededRandom(seed ^ i) - 0.5) * 2);
+      data.data[i]     = Math.max(0, Math.min(255, data.data[i]     + noise));
+      data.data[i + 1] = Math.max(0, Math.min(255, data.data[i + 1] + noise));
+      data.data[i + 2] = Math.max(0, Math.min(255, data.data[i + 2] + noise));
+    }
+    return data;
+  };
+
+  // --- Navigator: round hardware concurrency and device memory ---
+  const origConcurrency = Object.getOwnPropertyDescriptor(
+    Navigator.prototype, 'hardwareConcurrency');
+  if (origConcurrency) {
+    Object.defineProperty(Navigator.prototype, 'hardwareConcurrency', {
+      get: function() {
+        const real = origConcurrency.get.call(this);
+        // Round down to nearest power of 2 to reduce entropy.
+        return Math.pow(2, Math.floor(Math.log2(real)));
+      },
+      configurable: true,
+    });
+  }
+
+  // --- Screen: round to common display sizes ---
+  // (left as future work; requires OS-level interception)
+
+})()" + seed_str + R"JS();
+)JS";
+
+  v8::Local<v8::String> source =
+      v8::String::NewFromUtf8(isolate, shim.c_str(),
+                              v8::NewStringType::kNormal).ToLocalChecked();
+  v8::Local<v8::Script> script =
+      v8::Script::Compile(context, source).ToLocalChecked();
+  script->Run(context).IsEmpty();  // ignore result; errors go to console
+
+  VLOG(2) << "NickelFingerprint: injected shims (seed=" << noise_seed_ << ")";
+}
+
+}  // namespace nickel
