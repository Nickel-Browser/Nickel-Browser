+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_fingerprint_shield.h
+// Per-RenderFrame object that intercepts fingerprinting-sensitive APIs.
+//
+// Hooking strategy: Chrome 146 exposes ContentRendererClient virtual methods
+// and Blink's InternalSettings for overriding many sensor/hardware values.
+// For canvas/audio we use the approach pioneered by ungoogled-chromium's
+// fingerprinting patches: override at the IDL binding level.
+
+#ifndef CHROME_RENDERER_NICKEL_NICKEL_FINGERPRINT_SHIELD_H_
+#define CHROME_RENDERER_NICKEL_NICKEL_FINGERPRINT_SHIELD_H_
+
+#include <cstdint>
+
+#include "content/public/renderer/render_frame_observer.h"
+
+namespace blink {
+class WebLocalFrame;
+}
+
+namespace nickel {
+
+// Attached to each RenderFrame by NickelContentRendererClient.
+// Uses the per-session noise seed to perturb fingerprinting APIs.
+class NickelFingerprintShield : public content::RenderFrameObserver {
+ public:
+  NickelFingerprintShield(content::RenderFrame* render_frame,
+                          uint64_t noise_seed);
+  ~NickelFingerprintShield() override;
+
+  // RenderFrameObserver:
+  void DidCreateScriptContext(v8::Local<v8::Context> context,
+                              int32_t world_id) override;
+  void OnDestruct() override;
+
+ private:
+  // Injects noise-wrapping JS shims for Canvas, AudioContext, Navigator APIs.
+  void InjectFingerprintShims(v8::Local<v8::Context> context);
+
+  uint64_t noise_seed_;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_RENDERER_NICKEL_NICKEL_FINGERPRINT_SHIELD_H_
