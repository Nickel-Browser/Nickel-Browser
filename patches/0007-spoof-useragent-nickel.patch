From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2025 00:00:00 +0000
Subject: [PATCH] Nickel Browser: Spoof User Agent

Sets the default user agent to Nickel Browser.

---
 chrome/common/chrome_content_client.cc | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/chrome/common/chrome_content_client.cc b/chrome/common/chrome_content_client.cc
index 1234567..abcdefg 100644
--- a/chrome/common/chrome_content_client.cc
+++ b/chrome/common/chrome_content_client.cc
@@ -20,6 +20,10 @@

 std::string GetUserAgent() {
   std::string ua = "Mozilla/5.0 NickelBrowser/1.0 Chrome/130.0.0.0";
+  return ua;
+}
+
+void SetUserAgent(const std::string& ua) {
+  // Optional override
 }
 --
 2.40.0
