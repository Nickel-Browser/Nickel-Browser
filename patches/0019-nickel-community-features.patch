+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+// Nickel Dashboard - about:nickel page
+// Shows privacy stats, blocked trackers, and security status

+#include "chrome/browser/ui/nickel/nickel_dashboard.h"
+
+#include "base/i18n/number_formatting.h"
+#include "base/strings/stringprintf.h"
+#include "chrome/browser/nickel/adblock/adblock_controller.h"
+#include "chrome/browser/nickel/fingerprint/fingerprint_protection.h"
+#include "chrome/browser/nickel/tor/tor_controller.h"
+#include "chrome/browser/nickel/vpn/vpn_controller.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/url_constants.h"
+#include "chrome/grit/generated_resources.h"
+#include "components/strings/grit/components_strings.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/webui/web_ui_util.h"
+
+namespace nickel {
+
+namespace {
+
+// HTML template for about:nickel
+const char kNickelDashboardHtml[] = R"(
+<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>Nickel Dashboard</title>
+  <style>
+    body {
+      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
+      margin: 0;
+      padding: 0;
+      background: #1a1a2e;
+      color: #fff;
+      min-height: 100vh;
+    }
+    .header {
+      background: linear-gradient(135deg, #FF4500 0%, #1A1A1A 100%);
+      padding: 40px;
+      text-align: center;
+    }
+    .logo {
+      width: 80px;
+      height: 80px;
+      margin-bottom: 20px;
+    }
+    h1 {
+      margin: 0;
+      font-size: 32px;
+      font-weight: 600;
+    }
+    .tagline {
+      margin-top: 10px;
+      opacity: 0.8;
+      font-size: 16px;
+    }
+    .stats-grid {
+      display: grid;
+      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
+      gap: 20px;
+      padding: 40px;
+      max-width: 1200px;
+      margin: 0 auto;
+    }
+    .stat-card {
+      background: rgba(255,255,255,0.05);
+      border-radius: 12px;
+      padding: 24px;
+      border: 1px solid rgba(255,255,255,0.1);
+    }
+    .stat-value {
+      font-size: 36px;
+      font-weight: 700;
+      color: #00d4aa;
+      margin-bottom: 8px;
+    }
+    .stat-label {
+      font-size: 14px;
+      opacity: 0.7;
+      text-transform: uppercase;
+      letter-spacing: 0.5px;
+    }
+    .status-section {
+      padding: 40px;
+      max-width: 1200px;
+      margin: 0 auto;
+    }
+    .status-item {
+      display: flex;
+      align-items: center;
+      padding: 16px 0;
+      border-bottom: 1px solid rgba(255,255,255,0.1);
+    }
+    .status-icon {
+      width: 24px;
+      height: 24px;
+      margin-right: 16px;
+      border-radius: 50%;
+    }
+    .status-icon.enabled {
+      background: #00d4aa;
+    }
+    .status-icon.disabled {
+      background: #ff4757;
+    }
+    .status-text {
+      flex: 1;
+    }
+    .status-title {
+      font-weight: 500;
+      margin-bottom: 4px;
+    }
+    .status-desc {
+      font-size: 13px;
+      opacity: 0.6;
+    }
+    .footer {
+      text-align: center;
+      padding: 40px;
+      opacity: 0.5;
+      font-size: 13px;
+    }
+  </style>
+</head>
+<body>
+  <div class="header">
+    <img src="chrome://theme/IDR_NICKEL_LOGO" alt="Nickel" class="logo">
+    <h1>Nickel Browser</h1>
+    <div class="tagline">The browser the community always deserved</div>
+  </div>
+  
+  <div class="stats-grid">
+    <div class="stat-card">
+      <div class="stat-value" id="blocked-count">0</div>
+      <div class="stat-label">Trackers & Ads Blocked</div>
+    </div>
+    <div class="stat-card">
+      <div class="stat-value" id="data-saved">0 MB</div>
+      <div class="stat-label">Data Saved</div>
+    </div>
+    <div class="stat-card">
+      <div class="stat-value" id="time-saved">0 min</div>
+      <div class="stat-label">Time Saved</div>
+    </div>
+    <div class="stat-card">
+      <div class="stat-value" id="privacy-score">A+</div>
+      <div class="stat-label">Privacy Score</div>
+    </div>
+  </div>
+  
+  <div class="status-section">
+    <h2>Protection Status</h2>
+    <div id="status-list"></div>
+  </div>
+  
+  <div class="footer">
+    Nickel Browser v1.0.0 | Built with 💚 by the community
+  </div>
+  
+  <script>
+    // Load stats from browser
+    function loadStats() {
+      // This would be populated by C++ code
+      document.getElementById('blocked-count').textContent = 
+        '{BLOCKED_COUNT}';
+      document.getElementById('data-saved').textContent = 
+        '{DATA_SAVED}';
+      document.getElementById('time-saved').textContent = 
+        '{TIME_SAVED}';
+    }
+    loadStats();
+  </script>
+</body>
+</html>
+)";
+
+}  // namespace
+
+NickelDashboardUI::NickelDashboardUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  // Create data source
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kNickelHost);
+  
+  // Add localized strings
+  source->AddLocalizedString("title", IDS_NICKEL_DASHBOARD_TITLE);
+  source->AddLocalizedString("tagline", IDS_NICKEL_DASHBOARD_TAGLINE);
+  
+  // Generate HTML with stats
+  std::string html = kNickelDashboardHtml;
+  
+  // Get ad-block stats
+  auto* adblock = AdblockController::GetInstance();
+  if (adblock) {
+    base::ReplaceSubstringsAfterOffset(&html, 0, "{BLOCKED_COUNT}",
+        base::FormatNumber(adblock->GetBlockedCount()));
+  }
+  
+  // Set HTML
+  source->AddString("html", html);
+  source->SetDefaultResource(IDR_NICKEL_DASHBOARD_HTML);
+  
+  // Add resources
+  web_ui->RegisterMessageCallback(
+      "getStats",
+      base::BindRepeating(&NickelDashboardUI::HandleGetStats,
+                          base::Unretained(this)));
+}
+
+NickelDashboardUI::~NickelDashboardUI() = default;
+
+void NickelDashboardUI::HandleGetStats(const base::Value::List& args) {
+  // Return stats to JavaScript
+  base::Value::Dict stats;
+  
+  auto* adblock = AdblockController::GetInstance();
+  if (adblock) {
+    stats.Set("blockedCount", static_cast<int>(adblock->GetBlockedCount()));
+  }
+  
+  auto* tor = TorController::GetInstance();
+  if (tor) {
+    stats.Set("torConnected", tor->IsRunning());
+  }
+  
+  auto* vpn = VPNController::GetInstance();
+  if (vpn) {
+    stats.Set("vpnConnected", vpn->IsConnected());
+  }
+  
+  // Allow JavaScript to reply
+  AllowJavascript();
+  ResolveJavascriptCallback(args[0].GetString(), stats);
+}
+
+}  // namespace nickel

