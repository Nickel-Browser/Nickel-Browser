+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_UI_NICKEL_VERTICAL_TABS_H_
+#define CHROME_BROWSER_UI_NICKEL_VERTICAL_TABS_H_
+
+#include <vector>
+
+#include "chrome/browser/ui/tabs/tab_strip_model_observer.h"
+#include "ui/views/view.h"
+
+class Browser;
+class TabStripModel;
+
+namespace content {
+class WebContents;
+}
+
+namespace views {
+class View;
+}
+
+namespace nickel {
+
+class VerticalTabView;
+
+// Vertical tab strip container
+class VerticalTabStrip : public views::View,
+                         public TabStripModelObserver {
+ public:
+  VerticalTabStrip(Browser* browser, views::View* parent);
+  ~VerticalTabStrip() override;
+
+  // Show/hide vertical tabs
+  void SetVisible(bool visible);
+
+  // TabStripModelObserver overrides
+  void OnTabStripModelChanged(
+      TabStripModel* tab_strip_model,
+      const TabStripModelChange& change,
+      const TabStripSelectionChange& selection) override;
+  void TabChangedAt(content::WebContents* contents,
+                    int index,
+                    TabChangeType change_type) override;
+
+  // Select/close tabs
+  void SelectTabAt(int index);
+  void CloseTabAt(int index);
+
+ private:
+  void RebuildTabList();
+  void AddTabAt(int index, content::WebContents* contents);
+  void UpdateTabAt(int index);
+  void UpdateSelection(int active_index);
+
+  raw_ptr<Browser> browser_;
+  raw_ptr<views::View> parent_;
+  std::vector<raw_ptr<VerticalTabView>> tab_views_;
+};
+
+// Individual vertical tab view
+class VerticalTabView : public views::View {
+ public:
+  VerticalTabView(Browser* browser,
+                  content::WebContents* contents,
+                  VerticalTabStrip* strip);
+  ~VerticalTabView() override;
+
+  // Update from WebContents
+  void Update(content::WebContents* contents);
+
+  // Set selected state
+  void SetSelected(bool selected);
+
+ protected:
+  // views::View overrides
+  void OnPaint(gfx::Canvas* canvas) override;
+  bool OnMousePressed(const ui::MouseEvent& event) override;
+  void OnMouseEvent(ui::MouseEvent* event) override;
+
+ private:
+  raw_ptr<Browser> browser_;
+  raw_ptr<VerticalTabStrip> strip_;
+  bool selected_ = false;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_UI_NICKEL_VERTICAL_TABS_H_

