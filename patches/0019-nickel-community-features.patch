+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_UI_NICKEL_SPLIT_VIEW_H_
+#define CHROME_BROWSER_UI_NICKEL_SPLIT_VIEW_H_
+
+#include "ui/views/view.h"
+
+class Browser;
+
+namespace content {
+class WebContents;
+}
+
+namespace views {
+class View;
+}
+
+namespace nickel {
+
+class SplitViewDivider;
+
+// Split view modes
+enum class SplitMode {
+  kNone,      // No split
+  kVertical,  // Side-by-side
+  kHorizontal // Top-bottom
+};
+
+// Split view for viewing two tabs simultaneously
+class SplitView : public views::View {
+ public:
+  SplitView(Browser* browser, views::View* parent);
+  ~SplitView() override;
+
+  // Set split mode
+  void SetSplitMode(SplitMode mode);
+  SplitMode GetSplitMode() const { return split_mode_; }
+
+  // Set tabs for each pane
+  void SetLeftTab(int index);
+  void SetRightTab(int index);
+  void SwapTabs();
+
+ private:
+  void UpdateLayout();
+  void AddPane(content::WebContents* contents, bool is_left);
+  void AddDivider();
+
+  raw_ptr<Browser> browser_;
+  raw_ptr<views::View> parent_;
+  SplitMode split_mode_;
+  int left_tab_index_ = -1;
+  int right_tab_index_ = -1;
+};
+
+// Draggable divider between panes
+class SplitViewDivider : public views::View {
+ public:
+  explicit SplitViewDivider(SplitView* split_view);
+  ~SplitViewDivider() override;
+
+ protected:
+  // views::View overrides
+  bool OnMousePressed(const ui::MouseEvent& event) override;
+  bool OnMouseDragged(const ui::MouseEvent& event) override;
+  void OnMouseReleased(const ui::MouseEvent& event) override;
+  void OnMouseEntered(const ui::MouseEvent& event) override;
+  void OnMouseExited(const ui::MouseEvent& event) override;
+
+ private:
+  raw_ptr<SplitView> split_view_;
+  bool dragging_ = false;
+  int drag_start_x_ = 0;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_UI_NICKEL_SPLIT_VIEW_H_
+--
