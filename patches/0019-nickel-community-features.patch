+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/ui/nickel/workspace_manager.h"
+
+#include "base/guid.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "chrome/browser/profiles/profile.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+
+namespace nickel {
+
+namespace {
+
+constexpr char kWorkspacesPref[] = "nickel.workspaces";
+constexpr char kActiveWorkspacePref[] = "nickel.active_workspace";
+
+}  // namespace
+
+// static
+WorkspaceManager* WorkspaceManager::GetInstance() {
+  static base::NoDestructor<WorkspaceManager> instance;
+  return instance.get();
+}
+
+WorkspaceManager::WorkspaceManager() = default;
+
+WorkspaceManager::~WorkspaceManager() = default;
+
+void WorkspaceManager::Initialize(PrefService* prefs) {
+  prefs_ = prefs;
+  LoadWorkspaces();
+  
+  // Create default workspace if none exist
+  if (workspaces_.empty()) {
+    CreateWorkspace("Default", SkColorSetRGB(255, 69, 0));  // Nickel orange
+  }
+}
+
+std::vector<Workspace> WorkspaceManager::GetAllWorkspaces() const {
+  return workspaces_;
+}
+
+Workspace* WorkspaceManager::GetActiveWorkspace() {
+  std::string active_id = prefs_->GetString(kActiveWorkspacePref);
+  
+  for (auto& workspace : workspaces_) {
+    if (workspace.id == active_id) {
+      return &workspace;
+    }
+  }
+  
+  // Return first workspace if active not found
+  return workspaces_.empty() ? nullptr : &workspaces_[0];
+}
+
+Workspace* WorkspaceManager::CreateWorkspace(const std::string& name,
+                                              SkColor color) {
+  Workspace workspace;
+  workspace.id = base::GenerateGUID();
+  workspace.name = name;
+  workspace.color = color;
+  workspace.created_time = base::Time::Now();
+  
+  workspaces_.push_back(workspace);
+  SaveWorkspaces();
+  
+  VLOG(1) << "Nickel Workspace: Created " << name;
+  
+  return &workspaces_.back();
+}
+
+void WorkspaceManager::DeleteWorkspace(const std::string& id) {
+  workspaces_.erase(
+      std::remove_if(workspaces_.begin(), workspaces_.end(),
+                     [&id](const Workspace& w) { return w.id == id; }),
+      workspaces_.end());
+  
+  SaveWorkspaces();
+}
+
+void WorkspaceManager::RenameWorkspace(const std::string& id,
+                                        const std::string& new_name) {
+  for (auto& workspace : workspaces_) {
+    if (workspace.id == id) {
+      workspace.name = new_name;
+      SaveWorkspaces();
+      break;
+    }
+  }
+}
+
+void WorkspaceManager::SetActiveWorkspace(const std::string& id) {
+  prefs_->SetString(kActiveWorkspacePref, id);
+}
+
+void WorkspaceManager::LoadWorkspaces() {
+  const base::Value::List& workspaces_list = prefs_->GetList(kWorkspacesPref);
+  
+  for (const auto& workspace_value : workspaces_list) {
+    if (!workspace_value.is_dict()) {
+      continue;
+    }
+    
+    const base::Value::Dict& workspace_dict = workspace_value.GetDict();
+    Workspace workspace;
+    
+    if (const std::string* id = workspace_dict.FindString("id")) {
+      workspace.id = *id;
+    }
+    if (const std::string* name = workspace_dict.FindString("name")) {
+      workspace.name = *name;
+    }
+    if (std::optional<int> color = workspace_dict.FindInt("color")) {
+      workspace.color = static_cast<SkColor>(*color);
+    }
+    
+    workspaces_.push_back(workspace);
+  }
+}
+
+void WorkspaceManager::SaveWorkspaces() {
+  base::Value::List workspaces_list;
+  
+  for (const auto& workspace : workspaces_) {
+    base::Value::Dict workspace_dict;
+    workspace_dict.Set("id", workspace.id);
+    workspace_dict.Set("name", workspace.name);
+    workspace_dict.Set("color", static_cast<int>(workspace.color));
+    
+    workspaces_list.Append(std::move(workspace_dict));
+  }
+  
+  prefs_->SetList(kWorkspacesPref, std::move(workspaces_list));
+}
+
+}  // namespace nickel

