+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/ui/nickel/vertical_tabs.h"
+
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "chrome/browser/ui/views/tabs/tab.h"
+#include "chrome/common/pref_names.h"
+#include "chrome/grit/generated_resources.h"
+#include "components/prefs/pref_service.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/views/layout/box_layout.h"
+#include "ui/views/view.h"
+
+namespace nickel {
+
+namespace {
+
+constexpr int kVerticalTabWidth = 250;
+constexpr int kVerticalTabHeight = 36;
+constexpr int kVerticalTabPadding = 8;
+
+}  // namespace
+
+VerticalTabStrip::VerticalTabStrip(Browser* browser, views::View* parent)
+    : browser_(browser),
+      parent_(parent) {
+  // Set up layout
+  auto layout = std::make_unique<views::BoxLayout>(
+      views::BoxLayout::Orientation::kVertical);
+  layout->set_between_child_spacing(kVerticalTabPadding);
+  SetLayoutManager(std::move(layout));
+  
+  // Set preferred size
+  SetPreferredSize(gfx::Size(kVerticalTabWidth, 0));
+  
+  // Subscribe to tab changes
+  browser_->tab_strip_model()->AddObserver(this);
+  
+  // Build initial tab list
+  RebuildTabList();
+}
+
+VerticalTabStrip::~VerticalTabStrip() {
+  browser_->tab_strip_model()->RemoveObserver(this);
+}
+
+void VerticalTabStrip::SetVisible(bool visible) {
+  views::View::SetVisible(visible);
+  
+  // Save preference
+  PrefService* prefs = browser_->profile()->GetPrefs();
+  prefs->SetBoolean(prefs::kNickelVerticalTabsEnabled, visible);
+}
+
+void VerticalTabStrip::OnTabStripModelChanged(
+    TabStripModel* tab_strip_model,
+    const TabStripModelChange& change,
+    const TabStripSelectionChange& selection) {
+  RebuildTabList();
+}
+
+void VerticalTabStrip::TabChangedAt(content::WebContents* contents,
+                                     int index,
+                                     TabChangeType change_type) {
+  if (change_type == TabChangeType::kTitle ||
+      change_type == TabChangeType::kFavicon) {
+    UpdateTabAt(index);
+  }
+}
+
+void VerticalTabStrip::RebuildTabList() {
+  // Clear existing tabs
+  RemoveAllChildViews();
+  tab_views_.clear();
+  
+  TabStripModel* model = browser_->tab_strip_model();
+  
+  // Add tab for each WebContents
+  for (int i = 0; i < model->count(); ++i) {
+    AddTabAt(i, model->GetWebContentsAt(i));
+  }
+  
+  // Update selection
+  UpdateSelection(model->active_index());
+  
+  Layout();
+}
+
+void VerticalTabStrip::AddTabAt(int index, content::WebContents* contents) {
+  auto tab_view = std::make_unique<VerticalTabView>(
+      browser_, contents, this);
+  
+  VerticalTabView* tab_ptr = tab_view.get();
+  tab_views_.insert(tab_views_.begin() + index, tab_ptr);
+  
+  AddChildViewAt(std::move(tab_view), index);
+}
+
+void VerticalTabStrip::UpdateTabAt(int index) {
+  if (index < 0 || index >= static_cast<int>(tab_views_.size())) {
+    return;
+  }
+  
+  TabStripModel* model = browser_->tab_strip_model();
+  tab_views_[index]->Update(model->GetWebContentsAt(index));
+}
+
+void VerticalTabStrip::UpdateSelection(int active_index) {
+  for (size_t i = 0; i < tab_views_.size(); ++i) {
+    tab_views_[i]->SetSelected(static_cast<int>(i) == active_index);
+  }
+}
+
+void VerticalTabStrip::SelectTabAt(int index) {
+  browser_->tab_strip_model()->ActivateTabAt(index);
+}
+
+void VerticalTabStrip::CloseTabAt(int index) {
+  browser_->tab_strip_model()->CloseWebContentsAt(
+      index, TabStripModel::CLOSE_USER_GESTURE);
+}
+
+// VerticalTabView implementation
+
+VerticalTabView::VerticalTabView(Browser* browser,
+                                  content::WebContents* contents,
+                                  VerticalTabStrip* strip)
+    : browser_(browser),
+      strip_(strip) {
+  Update(contents);
+}
+
+VerticalTabView::~VerticalTabView() = default;
+
+void VerticalTabView::Update(content::WebContents* contents) {
+  // Update title
+  SetTooltipText(contents->GetTitle());
+  
+  // Update favicon
+  // TODO: Implement favicon loading
+}
+
+void VerticalTabView::SetSelected(bool selected) {
+  selected_ = selected;
+  
+  // Update visual state
+  if (selected) {
+    SetBackground(views::CreateSolidBackground(
+        SkColorSetARGB(255, 255, 69, 0)));  // Nickel orange
+  } else {
+    SetBackground(nullptr);
+  }
+}
+
+void VerticalTabView::OnPaint(gfx::Canvas* canvas) {
+  // Paint tab background
+  views::View::OnPaint(canvas);
+  
+  // Paint title
+  // TODO: Implement proper text rendering
+}
+
+bool VerticalTabView::OnMousePressed(const ui::MouseEvent& event) {
+  strip_->SelectTabAt(GetIndexInParent());
+  return true;
+}
+
+void VerticalTabView::OnMouseEvent(ui::MouseEvent* event) {
+  if (event->type() == ui::ET_MOUSE_RELEASED &&
+      event->IsMiddleMouseButton()) {
+    strip_->CloseTabAt(GetIndexInParent());
+    event->SetHandled();
+    return;
+  }
+  
+  views::View::OnMouseEvent(event);
+}
+
+}  // namespace nickel

