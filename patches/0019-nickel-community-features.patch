+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/ui/nickel/split_view.h"
+
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/views/layout/box_layout.h"
+#include "ui/views/view.h"
+
+namespace nickel {
+
+namespace {
+
+constexpr int kSplitViewDividerWidth = 8;
+
+}  // namespace
+
+SplitView::SplitView(Browser* browser, views::View* parent)
+    : browser_(browser),
+      parent_(parent),
+      split_mode_(SplitMode::kNone) {
+  // Set up layout
+  auto layout = std::make_unique<views::BoxLayout>(
+      views::BoxLayout::Orientation::kHorizontal);
+  layout->set_between_child_spacing(kSplitViewDividerWidth);
+  SetLayoutManager(std::move(layout));
+}
+
+SplitView::~SplitView() = default;
+
+void SplitView::SetSplitMode(SplitMode mode) {
+  if (split_mode_ == mode) {
+    return;
+  }
+  
+  split_mode_ = mode;
+  
+  // Update layout
+  UpdateLayout();
+}
+
+void SplitView::SetLeftTab(int index) {
+  left_tab_index_ = index;
+  UpdateLayout();
+}
+
+void SplitView::SetRightTab(int index) {
+  right_tab_index_ = index;
+  UpdateLayout();
+}
+
+void SplitView::SwapTabs() {
+  std::swap(left_tab_index_, right_tab_index_);
+  UpdateLayout();
+}
+
+void SplitView::UpdateLayout() {
+  // Clear existing views
+  RemoveAllChildViews();
+  
+  if (split_mode_ == SplitMode::kNone) {
+    // No split - show single active tab
+    return;
+  }
+  
+  TabStripModel* model = browser_->tab_strip_model();
+  
+  // Add left pane
+  if (left_tab_index_ >= 0 && left_tab_index_ < model->count()) {
+    content::WebContents* left_contents = model->GetWebContentsAt(left_tab_index_);
+    if (left_contents) {
+      AddPane(left_contents, true);
+    }
+  }
+  
+  // Add divider
+  AddDivider();
+  
+  // Add right pane
+  if (right_tab_index_ >= 0 && right_tab_index_ < model->count()) {
+    content::WebContents* right_contents = model->GetWebContentsAt(right_tab_index_);
+    if (right_contents) {
+      AddPane(right_contents, false);
+    }
+  }
+  
+  Layout();
+}
+
+void SplitView::AddPane(content::WebContents* contents, bool is_left) {
+  // Create view for WebContents
+  // This is simplified - actual implementation would use proper WebContents embedding
+  auto pane = std::make_unique<views::View>();
+  pane->SetPreferredSize(gfx::Size(400, 600));
+  
+  AddChildView(std::move(pane));
+}
+
+void SplitView::AddDivider() {
+  auto divider = std::make_unique<SplitViewDivider>(this);
+  AddChildView(std::move(divider));
+}
+
+// SplitViewDivider implementation
+
+SplitViewDivider::SplitViewDivider(SplitView* split_view)
+    : split_view_(split_view) {
+  SetPreferredSize(gfx::Size(kSplitViewDividerWidth, 0));
+  SetBackground(views::CreateSolidBackground(
+      SkColorSetARGB(255, 50, 50, 50)));
+}
+
+SplitViewDivider::~SplitViewDivider() = default;
+
+bool SplitViewDivider::OnMousePressed(const ui::MouseEvent& event) {
+  dragging_ = true;
+  drag_start_x_ = event.x();
+  return true;
+}
+
+bool SplitViewDivider::OnMouseDragged(const ui::MouseEvent& event) {
+  if (!dragging_) {
+    return false;
+  }
+  
+  int delta = event.x() - drag_start_x_;
+  // Notify split view of resize
+  // split_view_->ResizePanes(delta);
+  
+  return true;
+}
+
+void SplitViewDivider::OnMouseReleased(const ui::MouseEvent& event) {
+  dragging_ = false;
+}
+
+void SplitViewDivider::OnMouseEntered(const ui::MouseEvent& event) {
+  SetCursor(ui::Cursor(ui::mojom::CursorType::kEastWestResize));
+}
+
+void SplitViewDivider::OnMouseExited(const ui::MouseEvent& event) {
+  SetCursor(ui::Cursor(ui::mojom::CursorType::kNull));
+}
+
+}  // namespace nickel

