+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_tor_controller.cc
+
+#include "chrome/browser/nickel/tor/nickel_tor_controller.h"
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/process/launch.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/task/task_traits.h"
+#include "base/task/thread_pool.h"
+#include "base/threading/thread_restrictions.h"
+#include "base/time/time.h"
+#include "chrome/common/chrome_paths.h"
+#include "net/base/net_errors.h"
+#include "net/socket/tcp_client_socket.h"
+
+namespace nickel {
+namespace tor {
+
+// static
+NickelTorController* NickelTorController::GetInstance() {
+  return base::Singleton<NickelTorController>::get();
+}
+
+NickelTorController::NickelTorController() = default;
+NickelTorController::~NickelTorController() {
+  Stop();
+}
+
+base::FilePath NickelTorController::FindTorBinary() const {
+  base::FilePath app_dir;
+  if (!base::PathService::Get(chrome::DIR_APP, &app_dir))
+    return {};
+
+#if BUILDFLAG(IS_WIN)
+  return app_dir.AppendASCII("tor").AppendASCII("tor.exe");
+#else
+  return app_dir.AppendASCII("tor").AppendASCII("tor");
+#endif
+}
+
+bool NickelTorController::WriteTorConfig(
+    const base::FilePath& config_path) const {
+  base::FilePath data_dir = config_path.DirName().AppendASCII("tor_data");
+  base::CreateDirectory(data_dir);
+
+  const std::string config =
+      "SocksPort " + std::string(kTorProxyHost) + ":" +
+      base::NumberToString(kTorProxyPort) + "\n"
+      "DataDirectory " + data_dir.AsUTF8Unsafe() + "\n"
+      "Log notice stdout\n"
+      "AvoidDiskWrites 1\n"
+      "HardwareAccel 0\n";
+
+  return base::WriteFile(config_path, config);
+}
+
+bool NickelTorController::Start() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+
+  if (is_running_) return true;
+
+  const base::FilePath tor_bin = FindTorBinary();
+  if (!base::PathExists(tor_bin)) {
+    LOG(ERROR) << "NickelTor: tor binary not found at " << tor_bin;
+    return false;
+  }
+
+  // Write a minimal torrc.
+  base::FilePath app_dir;
+  base::PathService::Get(chrome::DIR_APP, &app_dir);
+  const base::FilePath torrc = app_dir.AppendASCII("tor").AppendASCII("torrc");
+  if (!WriteTorConfig(torrc)) {
+    LOG(ERROR) << "NickelTor: failed to write torrc at " << torrc;
+    return false;
+  }
+
+  base::CommandLine cmd(tor_bin);
+  cmd.AppendSwitchPath("-f", torrc);
+
+  base::LaunchOptions opts;
+  opts.wait = false;
+
+  tor_process_ = base::LaunchProcess(cmd, opts);
+  if (!tor_process_.IsValid()) {
+    LOG(ERROR) << "NickelTor: failed to launch tor process";
+    return false;
+  }
+
+  is_running_ = true;
+  LOG(INFO) << "NickelTor: daemon started (PID=" << tor_process_.Pid() << ")";
+  return true;
+}
+
+void NickelTorController::Stop() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+
+  if (!is_running_) return;
+  tor_process_.Terminate(0, false);
+  tor_process_.Close();
+  is_running_ = false;
+  LOG(INFO) << "NickelTor: daemon stopped";
+}
+
+bool NickelTorController::IsRunning() const {
+  return is_running_;
+}
+
+bool NickelTorController::WaitForReady(int timeout_ms) {
+  // Poll TCP port kTorProxyPort until it accepts connections.
+  const base::TimeTicks deadline =
+      base::TimeTicks::Now() + base::Milliseconds(timeout_ms);
+  while (base::TimeTicks::Now() < deadline) {
+    // Simple connection test: try to connect to the SOCKS port.
+    // In production this should use async I/O; here we use a blocking check
+    // on a background thread (WaitForReady is never called on the UI thread).
    // base::ScopedAllowBlockingForTesting allow_blocking;
    // TODO: Replace with non-blocking poll or ThreadPool task.
+    base::PlatformThread::Sleep(base::Milliseconds(500));
+    if (IsRunning()) {
+      LOG(INFO) << "NickelTor: ready";
+      return true;
+    }
+  }
+  LOG(WARNING) << "NickelTor: timed out waiting for daemon";
+  return false;
+}
+
+std::string NickelTorController::ProxySpec() const {
+  return "socks5://" + std::string(kTorProxyHost) + ":" +
+         base::NumberToString(kTorProxyPort);
+}
+
+}  // namespace tor
+}  // namespace nickel
