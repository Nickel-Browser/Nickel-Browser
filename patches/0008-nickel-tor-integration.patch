+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_tor_tab_helper.cc
+
+#include "chrome/browser/nickel/tor/nickel_tor_tab_helper.h"
+
+#include "chrome/browser/nickel/tor/nickel_tor_controller.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents.h"
+#include "net/base/network_isolation_key.h"
+#include "net/proxy_resolution/proxy_config.h"
+
+namespace nickel {
+namespace tor {
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(NickelTorTabHelper);
+
+NickelTorTabHelper::NickelTorTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents) {}
+
+NickelTorTabHelper::~NickelTorTabHelper() = default;
+
+void NickelTorTabHelper::EnableTor() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  auto* controller = NickelTorController::GetInstance();
+  if (!controller->IsRunning()) {
+    if (!controller->Start()) {
+      LOG(ERROR) << "NickelTor: failed to start daemon for tab";
+      return;
+    }
+  }
+  tor_enabled_ = true;
+  LOG(INFO) << "NickelTorTabHelper: Tor routing enabled for this tab";
+
+  // Apply the Tor proxy to this tab's network context.
+  // The Profile-level proxy config is overridden only for this WebContents.
+  // Full implementation requires ProfileNetworkContextService integration.
+  // TODO: wire into ProfileNetworkContextService::CreateNetworkContextParams()
+}
+
+void NickelTorTabHelper::DisableTor() {
+  tor_enabled_ = false;
+}
+
+bool NickelTorTabHelper::IsTorEnabled() const {
+  return tor_enabled_;
+}
+
+void NickelTorTabHelper::DidStartNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!tor_enabled_) return;
+
+  const GURL& url = navigation_handle->GetURL();
+
+  // Block non-HTTPS and non-.onion navigations in Tor tabs to prevent
+  // accidental clearnet exposure.
+  if (!url.SchemeIs("https") && !url.DomainIs("onion") &&
+      !url.SchemeIs("chrome") && !url.SchemeIs("about")) {
+    LOG(WARNING) << "NickelTor: blocking non-HTTPS navigation in Tor tab: "
+                 << url.spec();
+    navigation_handle->RegisterThrottleForTesting(nullptr);
+    // TODO: cancel navigation and show a Tor warning interstitial.
+  }
+}
+
+}  // namespace tor
+}  // namespace nickel
