+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_tor_tab_helper.h
+// Per-WebContents helper that routes network traffic via Tor when active.
+
+#ifndef CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_TAB_HELPER_H_
+#define CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_TAB_HELPER_H_
+
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+
+namespace content {
+class WebContents;
+}
+
+namespace nickel {
+namespace tor {
+
+class NickelTorTabHelper
+    : public content::WebContentsObserver,
+      public content::WebContentsUserData<NickelTorTabHelper> {
+ public:
+  ~NickelTorTabHelper() override;
+
+  NickelTorTabHelper(const NickelTorTabHelper&) = delete;
+  NickelTorTabHelper& operator=(const NickelTorTabHelper&) = delete;
+
+  // Enable Tor routing for this tab.
+  void EnableTor();
+  void DisableTor();
+  bool IsTorEnabled() const;
+
+  // WebContentsObserver:
+  void DidStartNavigation(
+      content::NavigationHandle* navigation_handle) override;
+
+ private:
+  explicit NickelTorTabHelper(content::WebContents* web_contents);
+  friend class content::WebContentsUserData<NickelTorTabHelper>;
+
+  bool tor_enabled_ = false;
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+}  // namespace tor
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_TAB_HELPER_H_
