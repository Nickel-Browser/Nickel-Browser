+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_tor_controller.h
+// Manages the lifecycle of the bundled Tor daemon process.
+
+#ifndef CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_CONTROLLER_H_
+#define CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_CONTROLLER_H_
+
+#include <memory>
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/memory/singleton.h"
+#include "base/process/process.h"
+#include "base/sequence_checker.h"
+
+namespace nickel {
+namespace tor {
+
+// SOCKS5 proxy address that the Tor daemon listens on.
+constexpr char kTorProxyHost[] = "127.0.0.1";
+constexpr int  kTorProxyPort   = 9150;
+
+// Browser-process singleton that owns the Tor daemon child process.
+class NickelTorController {
+ public:
+  static NickelTorController* GetInstance();
+
+  NickelTorController(const NickelTorController&) = delete;
+  NickelTorController& operator=(const NickelTorController&) = delete;
+
+  // Start the Tor daemon.  No-op if already running.
+  // Returns true on success.
+  bool Start();
+
+  // Stop the Tor daemon gracefully.
+  void Stop();
+
+  // Returns true if the Tor daemon is currently running and accepting
+  // connections on kTorProxyPort.
+  bool IsRunning() const;
+
+  // Block until the Tor daemon is ready (circuit established) or |timeout_ms|
+  // milliseconds have elapsed.  Returns true if ready.
+  bool WaitForReady(int timeout_ms = 30000);
+
+  // Returns the SOCKS5 proxy spec string suitable for use with
+  // net::ProxyConfig: "socks5://127.0.0.1:9150"
+  std::string ProxySpec() const;
+
+ private:
+  friend struct base::DefaultSingletonTraits<NickelTorController>;
+
+  NickelTorController();
+  ~NickelTorController();
+
+  base::FilePath FindTorBinary() const;
+  bool WriteTorConfig(const base::FilePath& config_path) const;
+
+  base::Process tor_process_;
+  bool is_running_ = false;
+
+  SEQUENCE_CHECKER(sequence_checker_);
+};
+
+}  // namespace tor
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_TOR_NICKEL_TOR_CONTROLLER_H_
