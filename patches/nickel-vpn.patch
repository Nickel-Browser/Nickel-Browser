diff --git a/chrome/browser/nickel/vpn/openvpn_manager.cc b/chrome/browser/nickel/vpn/openvpn_manager.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/chrome/browser/nickel/vpn/openvpn_manager.cc
@@ -0,0 +1,145 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/nickel/vpn/openvpn_manager.h"
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "base/process/launch.h"
+#include "base/process/process.h"
+#include "base/strings/string_util.h"
+
+namespace nickel {
+
+OpenVPNManager::OpenVPNManager() = default;
+
+OpenVPNManager::~OpenVPNManager() {
+  Disconnect();
+}
+
+bool OpenVPNManager::ValidateConfig(const std::string& config_data) {
+  // Basic OpenVPN config validation
+  // Must contain 'remote' directive
+  return config_data.find("remote ") != std::string::npos;
+}
+
+bool OpenVPNManager::Connect(const VPNConfig& config) {
+  if (process_.IsValid()) {
+    VLOG(1) << "Nickel OpenVPN: Already connected";
+    return true;
+  }
+  
+  // Create temporary config file
+  base::FilePath temp_dir;
+  if (!base::CreateNewTempDirectory("nickel_ovpn", &temp_dir)) {
+    LOG(ERROR) << "Nickel OpenVPN: Failed to create temp directory";
+    return false;
+  }
+  
+  config_file_ = temp_dir.Append("config.ovpn");
+  std::string config_with_auth = config.config_data;
+  
+  // Add auth if provided
+  if (!config.username.empty()) {
+    config_with_auth += "\nauth-user-pass " + temp_dir.Append("auth.txt").value();
+    std::string auth_data = config.username + "\n" + config.password;
+    base::WriteFile(temp_dir.Append("auth.txt"), auth_data);
+  }
+  
+  if (!base::WriteFile(config_file_, config_with_auth)) {
+    LOG(ERROR) << "Nickel OpenVPN: Failed to write config file";
+    return false;
+  }
+  
+  // Find openvpn binary
+  base::FilePath openvpn = FindOpenVPN();
+  if (openvpn.empty()) {
+    LOG(ERROR) << "Nickel OpenVPN: openvpn binary not found";
+    return false;
+  }
+  
+  // Launch OpenVPN
+  base::CommandLine cmdline(openvpn);
+  cmdline.AppendArg("--config");
+  cmdline.AppendArgPath(config_file_);
+  cmdline.AppendArg("--daemon");
+  
+  base::LaunchOptions options;
+  options.elevated = true;  // Need root for OpenVPN
+  
+  process_ = base::LaunchProcess(cmdline, options);
+  
+  if (!process_.IsValid()) {
+    LOG(ERROR) << "Nickel OpenVPN: Failed to launch openvpn";
+    return false;
+  }
+  
+  VLOG(1) << "Nickel OpenVPN: Connected successfully";
+  return true;
+}
+
+void OpenVPNManager::Disconnect() {
+  if (!process_.IsValid()) {
+    return;
+  }
+  
+  // Send SIGTERM to OpenVPN
+  process_.Terminate(0, false);
+  process_.WaitForExit(nullptr);
+  process_.Close();
+  
+  // Cleanup temp files
+  if (!config_file_.empty()) {
+    base::DeletePathRecursively(config_file_.DirName());
+  }
+  
+  VLOG(1) << "Nickel OpenVPN: Disconnected";
+}
+
+void OpenVPNManager::SetKillSwitch(bool enabled) {
+  // OpenVPN kill switch is handled via iptables/nftables rules
+  VLOG(1) << "Nickel OpenVPN: Kill switch " << (enabled ? "enabled" : "disabled");
+}
+
+base::FilePath OpenVPNManager::FindOpenVPN() {
+  std::vector<base::FilePath> search_paths = {
+      base::FilePath("/usr/sbin/openvpn"),
+      base::FilePath("/usr/local/sbin/openvpn"),
+      base::FilePath("/opt/local/sbin/openvpn"),
+  };
+  
+  for (const auto& path : search_paths) {
+    if (base::PathExists(path)) {
+      return path;
+    }
+  }
+  
+  return base::FilePath();
+}
+
+}  // namespace nickel

