+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_NICKEL_VPN_VPN_CONTROLLER_H_
+#define CHROME_BROWSER_NICKEL_VPN_VPN_CONTROLLER_H_
+
+#include <map>
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/no_destructor.h"
+#include "base/observer_list.h"
+#include "base/time/time.h"
+
+class PrefService;
+
+namespace nickel {
+
+class WireGuardManager;
+class OpenVPNManager;
+
+// VPN types supported
+enum class VPNType {
+  kNone,
+  kWireGuard,
+  kOpenVPN
+};
+
+// VPN connection state
+enum class VPNState {
+  kDisconnected,
+  kConnecting,
+  kConnected,
+  kDisconnecting,
+  kError
+};
+
+// VPN configuration
+struct VPNConfig {
+  std::string id;
+  std::string name;
+  VPNType type = VPNType::kNone;
+  std::string config_data;
+  std::string username;
+  std::string password;
+  base::Time created_time;
+};
+
+// Observer interface for VPN events
+class VPNObserver {
+ public:
+  virtual ~VPNObserver() = default;
+  
+  virtual void OnVPNConnected(const std::string& config_id) {}
+  virtual void OnVPNDisconnected() {}
+  virtual void OnVPNError(const std::string& error) {}
+};
+
+// Main controller for VPN integration
+class VPNController {
+ public:
+  // Returns the singleton instance
+  static VPNController* GetInstance();
+
+  // Initialize with preferences
+  void Initialize(PrefService* prefs);
+
+  // Get current state
+  VPNState GetState() const;
+  bool IsConnected() const;
+  
+  // Get configurations
+  std::string GetActiveConfigId() const;
+  const VPNConfig* GetActiveConfig() const;
+  std::vector<VPNConfig> GetAllConfigs() const;
+  
+  // Import configurations
+  bool ImportWireGuardConfig(const std::string& name,
+                             const std::string& config_data);
+  bool ImportOpenVPNConfig(const std::string& name,
+                           const std::string& config_data,
+                           const std::string& username = "",
+                           const std::string& password = "");
+  
+  // Connect/Disconnect
+  bool Connect(const std::string& config_id);
+  void Disconnect();
+  void DeleteConfig(const std::string& config_id);
+  
+  // Kill switch
+  void SetKillSwitchEnabled(bool enabled);
+  bool IsKillSwitchEnabled() const;
+  
+  // Observers
+  void AddObserver(VPNObserver* observer);
+  void RemoveObserver(VPNObserver* observer);
+
+ private:
+  VPNController();
+  ~VPNController();
+  
+  friend class base::NoDestructor<VPNController>;
+
+  void LoadConfigurations();
+  void SaveConfigurations();
+
+  VPNState state_;
+  VPNType active_type_;
+  std::string active_config_id_;
+  bool kill_switch_enabled_;
+  
+  std::map<std::string, VPNConfig> configs_;
+  std::unique_ptr<WireGuardManager> wireguard_manager_;
+  std::unique_ptr<OpenVPNManager> openvpn_manager_;
+  raw_ptr<PrefService> prefs_;
+  
+  base::ObserverList<VPNObserver> observers_;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_VPN_VPN_CONTROLLER_H_

diff --git a/chrome/browser/nickel/vpn/wireguard_manager.cc b/chrome/browser/nickel/vpn/wireguard_manager.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/chrome/browser/nickel/vpn/wireguard_manager.cc
@@ -0,0 +1,156 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/nickel/vpn/wireguard_manager.h"
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "base/process/launch.h"
+#include "base/process/process.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+
+namespace nickel {
+
+WireGuardManager::WireGuardManager() = default;
+
+WireGuardManager::~WireGuardManager() {
+  Disconnect();
+}
+
+bool WireGuardManager::ValidateConfig(const std::string& config_data) {
+  // Basic WireGuard config validation
+  // Must contain [Interface] and [Peer] sections
+  
+  bool has_interface = config_data.find("[Interface]") != std::string::npos;
+  bool has_peer = config_data.find("[Peer]") != std::string::npos;
+  
+  return has_interface && has_peer;
+}
+
+bool WireGuardManager::Connect(const VPNConfig& config) {
+  if (process_.IsValid()) {
+    VLOG(1) << "Nickel WireGuard: Already connected";
+    return true;
+  }
+  
+  // Create temporary config file
+  base::FilePath temp_dir;
+  if (!base::CreateNewTempDirectory("nickel_wg", &temp_dir)) {
+    LOG(ERROR) << "Nickel WireGuard: Failed to create temp directory";
+    return false;
+  }
+  
+  config_file_ = temp_dir.Append("config.conf");
+  if (!base::WriteFile(config_file_, config.config_data)) {
+    LOG(ERROR) << "Nickel WireGuard: Failed to write config file";
+    return false;
+  }
+  
+  // Find wg-quick
+  base::FilePath wg_quick = FindWgQuick();
+  if (wg_quick.empty()) {
+    LOG(ERROR) << "Nickel WireGuard: wg-quick not found";
+    return false;
+  }
+  
+  // Launch WireGuard
+  base::CommandLine cmdline(wg_quick);
+  cmdline.AppendArg("up");
+  cmdline.AppendArgPath(config_file_);
+  
+  base::LaunchOptions options;
+  options.elevated = true;  // Need root for WireGuard
+  
+  process_ = base::LaunchProcess(cmdline, options);
+  
+  if (!process_.IsValid()) {
+    LOG(ERROR) << "Nickel WireGuard: Failed to launch wg-quick";
+    return false;
+  }
+  
+  // Wait for connection
+  int exit_code;
+  if (!process_.WaitForExitWithTimeout(base::Seconds(10), &exit_code)) {
+    LOG(ERROR) << "Nickel WireGuard: Connection timeout";
+    process_.Terminate(0, false);
+    process_.Close();
+    return false;
+  }
+  
+  if (exit_code != 0) {
+    LOG(ERROR) << "Nickel WireGuard: Connection failed with exit code " 
+               << exit_code;
+    process_.Close();
+    return false;
+  }
+  
+  VLOG(1) << "Nickel WireGuard: Connected successfully";
+  return true;
+}
+
+void WireGuardManager::Disconnect() {
+  if (!process_.IsValid()) {
+    return;
+  }
+  
+  base::FilePath wg_quick = FindWgQuick();
+  if (!wg_quick.empty() && !config_file_.empty()) {
+    base::CommandLine cmdline(wg_quick);
+    cmdline.AppendArg("down");
+    cmdline.AppendArgPath(config_file_);
+    
+    base::LaunchOptions options;
+    options.elevated = true;
+    
+    base::Process down_process = base::LaunchProcess(cmdline, options);
+    down_process.WaitForExit(nullptr);
+  }
+  
+  process_.Close();
+  
+  // Cleanup temp files
+  if (!config_file_.empty()) {
+    base::DeletePathRecursively(config_file_.DirName());
+  }
+  
+  VLOG(1) << "Nickel WireGuard: Disconnected";
+}
+
+void WireGuardManager::SetKillSwitch(bool enabled) {
+  // WireGuard kill switch is handled via iptables/nftables rules
+  // This is a simplified implementation
+  VLOG(1) << "Nickel WireGuard: Kill switch " << (enabled ? "enabled" : "disabled");
+}
+
+base::FilePath WireGuardManager::FindWgQuick() {
+  std::vector<base::FilePath> search_paths = {
+      base::FilePath("/usr/bin/wg-quick"),
+      base::FilePath("/usr/local/bin/wg-quick"),
+      base::FilePath("/opt/local/bin/wg-quick"),
+  };
+  
+  for (const auto& path : search_paths) {
+    if (base::PathExists(path)) {
+      return path;
+    }
+  }
+  
+  return base::FilePath();
+}
+
+}  // namespace nickel

