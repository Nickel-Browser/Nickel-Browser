diff --git a/chrome/browser/nickel/vpn/vpn_controller.cc b/chrome/browser/nickel/vpn/vpn_controller.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/chrome/browser/nickel/vpn/vpn_controller.cc
@@ -0,0 +1,278 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+// VPN integration for Nickel Browser
+// Supports WireGuard and OpenVPN configurations

+#include "chrome/browser/nickel/vpn/vpn_controller.h"
+
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/strings/string_util.h"
+#include "chrome/browser/nickel/vpn/openvpn_manager.h"
+#include "chrome/browser/nickel/vpn/wireguard_manager.h"
+#include "chrome/common/chrome_paths.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+
+namespace nickel {
+
+namespace {
+
+// VPN configuration storage
+constexpr char kVPNConfigsPref[] = "nickel.vpn.configs";
+constexpr char kVPNActiveConfigPref[] = "nickel.vpn.active_config";
+constexpr char kVPNKillSwitchPref[] = "nickel.vpn.kill_switch";
+
+}  // namespace
+
+// static
+VPNController* VPNController::GetInstance() {
+  static base::NoDestructor<VPNController> instance;
+  return instance.get();
+}
+
+VPNController::VPNController()
+    : state_(VPNState::kDisconnected),
+      active_type_(VPNType::kNone),
+      kill_switch_enabled_(true) {}
+
+VPNController::~VPNController() {
+  Disconnect();
+}
+
+void VPNController::Initialize(PrefService* prefs) {
+  prefs_ = prefs;
+  
+  // Load saved configurations
+  LoadConfigurations();
+  
+  // Initialize managers
+  wireguard_manager_ = std::make_unique<WireGuardManager>();
+  openvpn_manager_ = std::make_unique<OpenVPNManager>();
+  
+  // Load kill switch preference
+  kill_switch_enabled_ = prefs_->GetBoolean(kVPNKillSwitchPref);
+  
+  VLOG(1) << "Nickel VPN: Initialized with " << configs_.size() 
+          << " configurations";
+}
+
+VPNState VPNController::GetState() const {
+  return state_;
+}
+
+bool VPNController::IsConnected() const {
+  return state_ == VPNState::kConnected;
+}
+
+std::string VPNController::GetActiveConfigId() const {
+  return active_config_id_;
+}
+
+const VPNConfig* VPNController::GetActiveConfig() const {
+  auto it = configs_.find(active_config_id_);
+  if (it != configs_.end()) {
+    return &it->second;
+  }
+  return nullptr;
+}
+
+std::vector<VPNConfig> VPNController::GetAllConfigs() const {
+  std::vector<VPNConfig> result;
+  for (const auto& [id, config] : configs_) {
+    result.push_back(config);
+  }
+  return result;
+}
+
+bool VPNController::ImportWireGuardConfig(const std::string& name,
+                                          const std::string& config_data) {
+  // Parse WireGuard config
+  VPNConfig config;
+  config.id = base::GenerateGUID();
+  config.name = name;
+  config.type = VPNType::kWireGuard;
+  config.config_data = config_data;
+  config.created_time = base::Time::Now();
+  
+  // Validate config
+  if (!wireguard_manager_->ValidateConfig(config_data)) {
+    LOG(ERROR) << "Nickel VPN: Invalid WireGuard configuration";
+    return false;
+  }
+  
+  // Save config
+  configs_[config.id] = config;
+  SaveConfigurations();
+  
+  VLOG(1) << "Nickel VPN: Imported WireGuard config: " << name;
+  return true;
+}
+
+bool VPNController::ImportOpenVPNConfig(const std::string& name,
+                                        const std::string& config_data,
+                                        const std::string& username,
+                                        const std::string& password) {
+  // Parse OpenVPN config
+  VPNConfig config;
+  config.id = base::GenerateGUID();
+  config.name = name;
+  config.type = VPNType::kOpenVPN;
+  config.config_data = config_data;
+  config.username = username;
+  config.password = password;
+  config.created_time = base::Time::Now();
+  
+  // Validate config
+  if (!openvpn_manager_->ValidateConfig(config_data)) {
+    LOG(ERROR) << "Nickel VPN: Invalid OpenVPN configuration";
+    return false;
+  }
+  
+  // Save config
+  configs_[config.id] = config;
+  SaveConfigurations();
+  
+  VLOG(1) << "Nickel VPN: Imported OpenVPN config: " << name;
+  return true;
+}
+
+bool VPNController::Connect(const std::string& config_id) {
+  if (state_ == VPNState::kConnecting || state_ == VPNState::kConnected) {
+    VLOG(1) << "Nickel VPN: Already connected or connecting";
+    return false;
+  }
+  
+  auto it = configs_.find(config_id);
+  if (it == configs_.end()) {
+    LOG(ERROR) << "Nickel VPN: Configuration not found: " << config_id;
+    return false;
+  }
+  
+  const VPNConfig& config = it->second;
+  
+  VLOG(1) << "Nickel VPN: Connecting to " << config.name;
+  
+  state_ = VPNState::kConnecting;
+  active_config_id_ = config_id;
+  active_type_ = config.type;
+  
+  // Connect based on type
+  bool success = false;
+  switch (config.type) {
+    case VPNType::kWireGuard:
+      success = wireguard_manager_->Connect(config);
+      break;
+    case VPNType::kOpenVPN:
+      success = openvpn_manager_->Connect(config);
+      break;
+    default:
+      LOG(ERROR) << "Nickel VPN: Unknown VPN type";
+      success = false;
+  }
+  
+  if (success) {
+    state_ = VPNState::kConnected;
+    prefs_->SetString(kVPNActiveConfigPref, config_id);
+    
+    // Notify observers
+    for (auto& observer : observers_) {
+      observer.OnVPNConnected(config_id);
+    }
+    
+    VLOG(1) << "Nickel VPN: Connected to " << config.name;
+  } else {
+    state_ = VPNState::kError;
+    LOG(ERROR) << "Nickel VPN: Failed to connect to " << config.name;
+  }
+  
+  return success;
+}
+
+void VPNController::Disconnect() {
+  if (state_ != VPNState::kConnected && state_ != VPNState::kConnecting) {
+    return;
+  }
+  
+  VLOG(1) << "Nickel VPN: Disconnecting...";
+  
+  // Disconnect based on type
+  switch (active_type_) {
+    case VPNType::kWireGuard:
+      wireguard_manager_->Disconnect();
+      break;
+    case VPNType::kOpenVPN:
+      openvpn_manager_->Disconnect();
+      break;
+    default:
+      break;
+  }
+  
+  state_ = VPNState::kDisconnected;
+  active_config_id_.clear();
+  active_type_ = VPNType::kNone;
+  prefs_->ClearPref(kVPNActiveConfigPref);
+  
+  // Notify observers
+  for (auto& observer : observers_) {
+    observer.OnVPNDisconnected();
+  }
+  
+  VLOG(1) << "Nickel VPN: Disconnected";
+}
+
+void VPNController::DeleteConfig(const std::string& config_id) {
+  // Disconnect if this config is active
+  if (active_config_id_ == config_id) {
+    Disconnect();
+  }
+  
+  configs_.erase(config_id);
+  SaveConfigurations();
+  
+  VLOG(1) << "Nickel VPN: Deleted configuration " << config_id;
+}
+
+void VPNController::SetKillSwitchEnabled(bool enabled) {
+  kill_switch_enabled_ = enabled;
+  prefs_->SetBoolean(kVPNKillSwitchPref, enabled);
+  
+  // Apply to active connection
+  if (state_ == VPNState::kConnected) {
+    switch (active_type_) {
+      case VPNType::kWireGuard:
+        wireguard_manager_->SetKillSwitch(enabled);
+        break;
+      case VPNType::kOpenVPN:
+        openvpn_manager_->SetKillSwitch(enabled);
+        break;
+      default:
+        break;
+    }
+  }
+}
+
+bool VPNController::IsKillSwitchEnabled() const {
+  return kill_switch_enabled_;
+}
+
+void VPNController::AddObserver(VPNObserver* observer) {
+  observers_.AddObserver(observer);
+}
+
+void VPNController::RemoveObserver(VPNObserver* observer) {
+  observers_.RemoveObserver(observer);
+}
+
+void VPNController::LoadConfigurations() {
+  const base::Value::Dict& configs_dict = prefs_->GetDict(kVPNConfigsPref);
+  
+  for (const auto [id, config_value] : configs_dict) {
+    if (!config_value.is_dict()) {
+      continue;
+    }
+    
+    const base::Value::Dict& config_dict = config_value.GetDict();
+    VPNConfig config;
+    
+    config.id = id;
+    if (const std::string* name = config_dict.FindString("name")) {
+      config.name = *name;
+    }
+    if (const std::string* type_str = config_dict.FindString("type")) {
+      if (*type_str == "wireguard") {
+        config.type = VPNType::kWireGuard;
+      } else if (*type_str == "openvpn") {
+        config.type = VPNType::kOpenVPN;
+      }
+    }
+    if (const std::string* config_data = config_dict.FindString("config_data")) {
+      config.config_data = *config_data;
+    }
+    if (const std::string* username = config_dict.FindString("username")) {
+      config.username = *username;
+    }
+    
+    configs_[id] = config;
+  }
+  
+  // Load active config
+  active_config_id_ = prefs_->GetString(kVPNActiveConfigPref);
+}
+
+void VPNController::SaveConfigurations() {
+  base::Value::Dict configs_dict;
+  
+  for (const auto& [id, config] : configs_) {
+    base::Value::Dict config_dict;
+    config_dict.Set("name", config.name);
+    config_dict.Set("type", config.type == VPNType::kWireGuard ? "wireguard" : "openvpn");
+    config_dict.Set("config_data", config.config_data);
+    if (!config.username.empty()) {
+      config_dict.Set("username", config.username);
+    }
+    
+    configs_dict.Set(id, std::move(config_dict));
+  }
+  
+  prefs_->SetDict(kVPNConfigsPref, std::move(configs_dict));
+}
+
+}  // namespace nickel

