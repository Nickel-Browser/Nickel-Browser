+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/ui/vpn/vpn_button.h"
+
+#include "chrome/browser/nickel/vpn/vpn_controller.h"
+#include "chrome/grit/generated_resources.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/models/image_model.h"
+#include "ui/gfx/paint_vector_icon.h"
+#include "ui/gfx/vector_icon_types.h"
+
+namespace nickel {
+
+VPNButton::VPNButton(Browser* browser)
+    : browser_(browser) {
+  UpdateButtonState();
+  
+  // Observe VPN state changes
+  VPNController::GetInstance()->AddObserver(this);
+}
+
+VPNButton::~VPNButton() {
+  VPNController::GetInstance()->RemoveObserver(this);
+}
+
+void VPNButton::OnClick() {
+  auto* controller = VPNController::GetInstance();
+  
+  if (controller->IsConnected()) {
+    // Show disconnect confirmation or menu
+    controller->Disconnect();
+  } else {
+    // Show VPN selection menu
+    ShowVPNMenu();
+  }
+}
+
+void VPNButton::OnVPNConnected(const std::string& config_id) {
+  UpdateButtonState();
+}
+
+void VPNButton::OnVPNDisconnected() {
+  UpdateButtonState();
+}
+
+void VPNButton::UpdateButtonState() {
+  auto* controller = VPNController::GetInstance();
+  
+  switch (controller->GetState()) {
+    case VPNState::kConnected:
+      SetTooltipText(l10n_util::GetStringUTF16(IDS_NICKEL_VPN_CONNECTED));
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kVPNConnectedIcon));
+      break;
+    case VPNState::kConnecting:
+      SetTooltipText(l10n_util::GetStringUTF16(IDS_NICKEL_VPN_CONNECTING));
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kVPNConnectingIcon));
+      break;
+    default:
+      SetTooltipText(l10n_util::GetStringUTF16(IDS_NICKEL_VPN_DISCONNECTED));
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kVPNDisconnectedIcon));
+      break;
+  }
+}
+
+void VPNButton::ShowVPNMenu() {
+  // Show VPN configuration menu
+  // This would display available VPN configs and allow selection
+  auto* controller = VPNController::GetInstance();
+  auto configs = controller->GetAllConfigs();
+  
+  if (configs.empty()) {
+    // Show "No VPN configured" message
+    // Open VPN settings
+  } else if (configs.size() == 1) {
+    // Connect to the only config
+    controller->Connect(configs[0].id);
+  } else {
+    // Show menu with all configs
+  }
+}
+
+}  // namespace nickel

