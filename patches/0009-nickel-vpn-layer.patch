 chrome/browser/nickel/vpn/nickel_vpn_service.h  | 54 ++++++++++
 2 files changed, 141 insertions(+)
 create mode 100644 chrome/browser/nickel/vpn/nickel_vpn_service.cc
 create mode 100644 chrome/browser/nickel/vpn/nickel_vpn_service.h

