+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_vpn_service.h
+// VPN proxy routing service for Nickel Browser.
+//
+// MVP: SOCKS5 / HTTP proxy forwarding.
+// Future: WireGuard kernel adapter.
+
+#ifndef CHROME_BROWSER_NICKEL_VPN_NICKEL_VPN_SERVICE_H_
+#define CHROME_BROWSER_NICKEL_VPN_NICKEL_VPN_SERVICE_H_
+
+#include <string>
+
+#include "components/keyed_service/core/keyed_service.h"
+
+class Profile;
+
+namespace net {
+class ProxyConfig;
+}
+
+namespace nickel {
+namespace vpn {
+
+// VPN connection configuration.
+struct VPNConfig {
+  enum class Type { kNone, kSocks5, kHttpProxy, kWireGuard };
+
+  Type type = Type::kNone;
+  std::string proxy_host;
+  int         proxy_port = 0;
+  std::string username;
+  std::string password;  // stored in the OS keychain, not here directly
+};
+
+class NickelVPNService : public KeyedService {
+ public:
+  explicit NickelVPNService(Profile* profile);
+  ~NickelVPNService() override;
+
+  NickelVPNService(const NickelVPNService&) = delete;
+  NickelVPNService& operator=(const NickelVPNService&) = delete;
+
+  bool Connect(const VPNConfig& config);
+  void Disconnect();
+  bool IsConnected() const;
+  VPNConfig CurrentConfig() const;
+
+  // Returns a net::ProxyConfig suitable for routing traffic via the VPN.
+  net::ProxyConfig BuildProxyConfig() const;
+
+ private:
+  Profile* profile_;  // not owned
+  VPNConfig config_;
+  bool connected_ = false;
+};
+
+}  // namespace vpn
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_VPN_NICKEL_VPN_SERVICE_H_
