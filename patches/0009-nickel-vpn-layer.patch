+++ b/chrome/browser/nickel/vpn/nickel_vpn_service.cc
@@ -0,0 +1,87 @@
+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_vpn_service.cc
+
+#include "chrome/browser/nickel/vpn/nickel_vpn_service.h"
+
+#include "base/logging.h"
+#include "chrome/browser/profiles/profile.h"
+#include "net/proxy_resolution/proxy_config.h"
+#include "net/proxy_resolution/proxy_config_service_fixed.h"
+
+namespace nickel {
+namespace vpn {
+
+NickelVPNService::NickelVPNService(Profile* profile)
+    : profile_(profile) {}
+
+NickelVPNService::~NickelVPNService() = default;
+
+bool NickelVPNService::Connect(const VPNConfig& config) {
+  if (config.type == VPNConfig::Type::kNone) {
+    LOG(WARNING) << "NickelVPN: no VPN type specified";
+    return false;
+  }
+
+  if (config.proxy_host.empty()) {
+    LOG(ERROR) << "NickelVPN: proxy host is empty";
+    return false;
+  }
+
+  config_    = config;
+  connected_ = true;
+
+  LOG(INFO) << "NickelVPN: connected via "
+            << config.proxy_host << ":" << config.proxy_port;
+  return true;
+}
+
+void NickelVPNService::Disconnect() {
+  connected_ = false;
+  config_    = {};
+  LOG(INFO) << "NickelVPN: disconnected";
+}
+
+bool NickelVPNService::IsConnected() const {
+  return connected_;
+}
+
+VPNConfig NickelVPNService::CurrentConfig() const {
+  return config_;
+}
+
+net::ProxyConfig NickelVPNService::BuildProxyConfig() const {
+  if (!connected_) return net::ProxyConfig::CreateDirect();
+
+  net::ProxyConfig config;
+  std::string proxy_uri;
+
+  switch (config_.type) {
+    case VPNConfig::Type::kSocks5:
+      proxy_uri = "socks5://" + config_.proxy_host + ":" +
+                  std::to_string(config_.proxy_port);
+      break;
+    case VPNConfig::Type::kHttpProxy:
+      proxy_uri = "http://" + config_.proxy_host + ":" +
+                  std::to_string(config_.proxy_port);
+      break;
+    case VPNConfig::Type::kWireGuard:
+      // WireGuard routes at the OS level; no proxy config needed.
+      return net::ProxyConfig::CreateDirect();
+    case VPNConfig::Type::kNone:
+    default:
+      return net::ProxyConfig::CreateDirect();
+  }
+
+  config.proxy_rules().ParseFromString("*=" + proxy_uri);
+  // Bypass localhost.
+  config.proxy_rules().bypass_rules.AddRuleFromString("localhost");
+  config.proxy_rules().bypass_rules.AddRuleFromString("127.0.0.1");
+  return config;
+}
+
+}  // namespace vpn
+}  // namespace nickel
