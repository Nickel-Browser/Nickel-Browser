From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2025 00:00:00 +0000
Subject: [PATCH] Nickel Browser: Branding and Identity

This patch replaces all Chromium branding with Nickel Browser branding,
including the Royal Bengal Tiger logo integration.

---
 chrome/app/chromium_strings.grd         | 200 +++++++++++-----------
 chrome/app/theme/chromium/BRANDING      |  16 +-
 chrome/common/chrome_constants.cc       |   8 +-
 components/version_info/version_info.cc |   4 +-
 4 files changed, 114 insertions(+), 114 deletions(-)

diff --git a/chrome/app/chromium_strings.grd b/chrome/app/chromium_strings.grd
index 1234567..abcdefg 100644
--- a/chrome/app/chromium_strings.grd
+++ b/chrome/app/chromium_strings.grd
@@ -1,7 +1,7 @@
 <?xml version="1.0" encoding="UTF-8"?>
 <grit latest_public_release="0" current_release="1" output_all_resource_defines="false">
   <outputs>
-    <output filename="grit/chromium_strings.h" type="rc_header">
+    <output filename="grit/nickel_strings.h" type="rc_header">
       <emit emit_type='prepend'></emit>
     </output>
     <output filename="chromium_strings_am.pak" lang="am" type="data_package"/>
@@ -45,100 +45,100 @@
