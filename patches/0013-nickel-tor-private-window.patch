+
+#include "chrome/browser/ui/tor/tor_new_tab_button.h"
+
+#include "chrome/browser/nickel/tor/tor_controller.h"
+#include "chrome/browser/nickel/tor/tor_tab_helper.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_commands.h"
+#include "chrome/grit/generated_resources.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/models/image_model.h"
+#include "ui/gfx/paint_vector_icon.h"
+#include "ui/gfx/vector_icon_types.h"
+
+namespace nickel {
+
+TorNewTabButton::TorNewTabButton(Browser* browser)
+    : browser_(browser) {
+  SetTooltipText(l10n_util::GetStringUTF16(IDS_NICKEL_NEW_TOR_TAB));
+  SetAccessibleName(l10n_util::GetStringUTF16(IDS_NICKEL_NEW_TOR_TAB));
+}
+
+TorNewTabButton::~TorNewTabButton() = default;
+
+void TorNewTabButton::OnClick() {
+  // Create new Tor tab
+  content::WebContents* web_contents = chrome::AddSelectedTabWithURL(
+      browser_,
+      GURL("about:tor"),  // Tor new tab page
+      ui::PAGE_TRANSITION_AUTO_BOOKMARK);
+  
+  if (web_contents) {
+    // Mark as Tor tab
+    TorTabHelper::CreateForWebContents(web_contents, true);
+    
+    // Ensure Tor is running
+    auto* tor_controller = TorController::GetInstance();
+    if (!tor_controller->IsRunning()) {
+      tor_controller->Start();
+    }
+  }
+}
+
+void TorNewTabButton::UpdateButtonState() {
+  auto* tor_controller = TorController::GetInstance();
+  
+  // Update icon based on Tor state
+  switch (tor_controller->GetState()) {
+    case TorState::kRunning:
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kTorConnectedIcon));
+      break;
+    case TorState::kStarting:
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kTorConnectingIcon));
+      break;
+    default:
+      SetImageModel(views::Button::STATE_NORMAL,
+                    ui::ImageModel::FromVectorIcon(kTorDisconnectedIcon));
+      break;
+  }
+}
+
+}  // namespace nickel

