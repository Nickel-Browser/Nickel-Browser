@@ -0,0 +1,345 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+// Tor integration for Nickel Browser
+// Uses official Tor binary from Tor Project

+#include "chrome/browser/nickel/tor/tor_controller.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/process/launch.h"
+#include "base/process/process.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+#include "base/task/thread_pool.h"
+#include "chrome/common/chrome_paths.h"
+#include "content/public/browser/browser_thread.h"
+#include "net/base/ip_address.h"
+#include "net/base/ip_endpoint.h"
+#include "net/log/net_log_source.h"
+#include "net/socket/tcp_server_socket.h"
+
+namespace nickel {
+
+namespace {
+
+// Tor configuration
+constexpr char kTorExecutableName[] = "tor";
+constexpr int kTorSocksPort = 9150;
+constexpr int kTorControlPort = 9151;
+constexpr char kTorControlPassword[] = "nickel_tor_control";  // Changed per session
+constexpr int kTorCircuitBuildTimeout = 60;
+constexpr int kTorMaxCircuitDirtiness = 600;  // 10 minutes
+
+// Tor configuration template
+const char kTorConfigTemplate[] = R"(
+# Nickel Browser Tor Configuration
+# Auto-generated - DO NOT EDIT

+SocksPort {SOCKS_PORT}
+ControlPort {CONTROL_PORT}
+HashedControlPassword {CONTROL_PASSWORD_HASH}
+CookieAuthentication 0
+
+# Security settings
+Sandbox 1
+DisableDebuggerAttachment 1
+
+# Circuit settings
+MaxCircuitDirtiness {MAX_CIRCUIT_DIRTINESS}
+NewCircuitPeriod 10
+UseEntryGuards 1
+
+# Privacy settings
+ClientOnly 1
+ClientUseIPv6 1
+ClientPreferIPv6ORPort 1
+
+# Logging
+Log notice stdout
+
+# Bridges (user-configurable)
+# {BRIDGES}
+
+# Exit nodes (user-configurable)
+# {EXIT_NODES}
+)
+";
+
+}  // namespace
+
+// static
+TorController* TorController::GetInstance() {
+  static base::NoDestructor<TorController> instance;
+  return instance.get();
+}
+
+TorController::TorController()
+    : state_(TorState::kNotInitialized),
+      socks_port_(kTorSocksPort),
+      control_port_(kTorControlPort),
+      process_(base::Process()) {}
+
+TorController::~TorController() {
+  Shutdown();
+}
+
+void TorController::Initialize() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  
+  if (state_ != TorState::kNotInitialized) {
+    VLOG(1) << "Nickel Tor: Already initialized";
+    return;
+  }
+  
+  VLOG(1) << "Nickel Tor: Initializing...";
+  
+  // Find Tor executable
+  if (!FindTorExecutable()) {
+    LOG(ERROR) << "Nickel Tor: Failed to find Tor executable";
+    state_ = TorState::kError;
+    return;
+  }
+  
+  // Generate control password
+  control_password_ = GenerateControlPassword();
+  
+  // Create Tor configuration
+  if (!CreateTorConfig()) {
+    LOG(ERROR) << "Nickel Tor: Failed to create Tor configuration";
+    state_ = TorState::kError;
+    return;
+  }
+  
+  VLOG(1) << "Nickel Tor: Initialization complete, ready to start";
+  state_ = TorState::kStopped;
+}
+
+void TorController::Shutdown() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  
+  if (process_.IsValid()) {
+    VLOG(1) << "Nickel Tor: Shutting down...";
+    
+    // Send control command to gracefully shutdown
+    SendControlCommand("SIGNAL SHUTDOWN");
+    
+    // Wait for process to exit
+    int exit_code;
+    process_.WaitForExitWithTimeout(base::Seconds(30), &exit_code);
+    
+    // Force kill if still running
+    if (process_.IsValid()) {
+      process_.Terminate(0, false);
+    }
+    
+    process_.Close();
+  }
+  
+  // Clean up temporary files
+  if (!config_dir_.empty()) {
+    base::DeletePathRecursively(config_dir_);
+  }
+  
+  state_ = TorState::kNotInitialized;
+  VLOG(1) << "Nickel Tor: Shutdown complete";
+}
+
+bool TorController::Start() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  
+  if (state_ == TorState::kRunning) {
+    VLOG(1) << "Nickel Tor: Already running";
+    return true;
+  }
+  
+  if (state_ != TorState::kStopped) {
+    LOG(ERROR) << "Nickel Tor: Cannot start from state " 
+               << static_cast<int>(state_);
+    return false;
+  }
+  
+  VLOG(1) << "Nickel Tor: Starting...";
+  
+  // Launch Tor process
+  if (!LaunchTorProcess()) {
+    LOG(ERROR) << "Nickel Tor: Failed to launch Tor process";
+    state_ = TorState::kError;
+    return false;
+  }
+  
+  // Wait for Tor to be ready
+  if (!WaitForTorReady()) {
+    LOG(ERROR) << "Nickel Tor: Tor failed to become ready";
+    Stop();
+    state_ = TorState::kError;
+    return false;
+  }
+  
+  state_ = TorState::kRunning;
+  VLOG(1) << "Nickel Tor: Started successfully";
+  
+  // Notify observers
+  for (auto& observer : observers_) {
+    observer.OnTorStarted();
+  }
+  
+  return true;
+}
+
+void TorController::Stop() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  
+  if (state_ != TorState::kRunning) {
+    return;
+  }
+  
+  VLOG(1) << "Nickel Tor: Stopping...";
+  
+  // Send shutdown signal
+  SendControlCommand("SIGNAL SHUTDOWN");
+  
+  // Wait for exit
+  int exit_code;
+  process_.WaitForExitWithTimeout(base::Seconds(30), &exit_code);
+  
+  // Force terminate if needed
+  if (process_.IsValid()) {
+    process_.Terminate(0, false);
+    process_.Close();
+  }
+  
+  state_ = TorState::kStopped;
+  VLOG(1) << "Nickel Tor: Stopped";
+  
+  // Notify observers
+  for (auto& observer : observers_) {
+    observer.OnTorStopped();
+  }
+}
+
+void TorController::NewIdentity() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  
+  if (state_ != TorState::kRunning) {
+    LOG(WARNING) << "Nickel Tor: Cannot get new identity, Tor not running";
+    return;
+  }
+  
+  VLOG(1) << "Nickel Tor: Requesting new identity...";
+  
+  // Send NEWNYM signal
+  SendControlCommand("SIGNAL NEWNYM");
+  
+  // Notify observers
+  for (auto& observer : observers_) {
+    observer.OnTorNewIdentity();
+  }
+}
+
+TorState TorController::GetState() const {
+  return state_;
+}
+
+bool TorController::IsRunning() const {
+  return state_ == TorState::kRunning;
+}
+
+int TorController::GetSocksPort() const {
+  return socks_port_;
+}
+
+net::ProxyServer TorController::GetProxyServer() const {
+  return net::ProxyServer(
+      net::ProxyServer::SCHEME_SOCKS5,
+      net::HostPortPair("127.0.0.1", socks_port_));
+}
+
+void TorController::AddObserver(TorObserver* observer) {
+  observers_.AddObserver(observer);
+}
+
+void TorController::RemoveObserver(TorObserver* observer) {
+  observers_.RemoveObserver(observer);
+}
+
+bool TorController::FindTorExecutable() {
+  // Check bundled Tor first
+  base::FilePath chrome_dir;
+  if (base::PathService::Get(base::DIR_EXE, &chrome_dir)) {
+    base::FilePath bundled_tor = chrome_dir.Append("tor").Append(kTorExecutableName);
+    if (base::PathExists(bundled_tor)) {
+      tor_executable_ = bundled_tor;
+      VLOG(1) << "Nickel Tor: Found bundled Tor at " << bundled_tor.value();
+      return true;
+    }
+  }
+  
+  // Check system Tor
+  std::vector<base::FilePath> search_paths = {
+      base::FilePath("/usr/bin/tor"),
+      base::FilePath("/usr/local/bin/tor"),
+      base::FilePath("/opt/local/bin/tor"),
+  };
+  
+  for (const auto& path : search_paths) {
+    if (base::PathExists(path)) {
+      tor_executable_ = path;
+      VLOG(1) << "Nickel Tor: Found system Tor at " << path.value();
+      return true;
+    }
+  }
+  
+  LOG(ERROR) << "Nickel Tor: Tor executable not found";
+  return false;
+}
+
+bool TorController::CreateTorConfig() {
+  // Create temporary directory for Tor config
+  base::FilePath temp_dir;
+  if (!base::CreateNewTempDirectory("nickel_tor", &temp_dir)) {
+    LOG(ERROR) << "Nickel Tor: Failed to create temp directory";
+    return false;
+  }
+  
+  config_dir_ = temp_dir;
+  
+  // Generate config file
+  std::string config = kTorConfigTemplate;
+  base::ReplaceSubstringsAfterOffset(&config, 0, "{SOCKS_PORT}",
+                                     base::NumberToString(socks_port_));
+  base::ReplaceSubstringsAfterOffset(&config, 0, "{CONTROL_PORT}",
+                                     base::NumberToString(control_port_));
+  base::ReplaceSubstringsAfterOffset(&config, 0, "{CONTROL_PASSWORD_HASH}",
+                                     HashControlPassword(control_password_));
+  base::ReplaceSubstringsAfterOffset(&config, 0, "{MAX_CIRCUIT_DIRTINESS}",
+                                     base::NumberToString(kTorMaxCircuitDirtiness));
+  
+  // Write config file
+  base::FilePath config_file = config_dir_.Append("torrc");
+  if (!base::WriteFile(config_file, config)) {
+    LOG(ERROR) << "Nickel Tor: Failed to write config file";
+    return false;
+  }
+  
+  config_file_ = config_file;
+  VLOG(1) << "Nickel Tor: Config created at " << config_file.value();
+  
+  return true;
+}
+
+bool TorController::LaunchTorProcess() {
+  base::CommandLine cmdline(tor_executable_);
+  cmdline.AppendArg("-f");
+  cmdline.AppendArgPath(config_file_);
+  
+  base::LaunchOptions options;
+  options.current_directory = config_dir_;
+  
+  process_ = base::LaunchProcess(cmdline, options);
+  
+  if (!process_.IsValid()) {
+    LOG(ERROR) << "Nickel Tor: Failed to launch Tor process";
+    return false;
+  }
+  
+  VLOG(1) << "Nickel Tor: Process launched with PID " << process_.Pid();
+  return true;
+}
+
+bool TorController::WaitForTorReady() {
+  // Wait up to 60 seconds for Tor to be ready
+  for (int i = 0; i < 60; ++i) {
+    if (CheckTorReady()) {
+      return true;
+    }
+    
+    // Check if process is still running
+    if (!process_.IsRunning()) {
+      LOG(ERROR) << "Nickel Tor: Process exited unexpectedly";
+      return false;
+    }
+    
+    base::PlatformThread::Sleep(base::Seconds(1));
+  }
+  
+  LOG(ERROR) << "Nickel Tor: Timeout waiting for Tor to be ready";
+  return false;
+}
+
+bool TorController::CheckTorReady() {
+  // Try to connect to control port and check status
+  // Simplified implementation
+  return SendControlCommand("GETINFO status/circuit-established") == "1";
+}
+
+std::string TorController::SendControlCommand(const std::string& command) {
+  // Simplified control port communication
+  // In production, this would use proper TCP socket communication
+  VLOG(2) << "Nickel Tor: Control command: " << command;
+  return "";
+}
+
+std::string TorController::GenerateControlPassword() {
+  // Generate random password
+  const int kPasswordLength = 32;
+  const char kPasswordChars[] = 
+      "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
+  
+  std::string password;
+  password.reserve(kPasswordLength);
+  
+  for (int i = 0; i < kPasswordLength; ++i) {
+    password += kPasswordChars[base::RandGenerator(sizeof(kPasswordChars) - 1)];
+  }
+  
+  return password;
+}
+
+std::string TorController::HashControlPassword(const std::string& password) {
+  // In production, this would use Tor's password hashing algorithm
+  // For now, return a placeholder
+  return "16:" + password;  // Simplified
+}
+
+}  // namespace nickel

