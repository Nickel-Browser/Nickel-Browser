+
+#ifndef CHROME_BROWSER_NICKEL_TOR_TOR_TAB_HELPER_H_
+#define CHROME_BROWSER_NICKEL_TOR_TOR_TAB_HELPER_H_
+
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+
+namespace nickel {
+
+// Helper class to manage Tor-specific behavior per tab
+class TorTabHelper : public content::WebContentsObserver,
+                     public content::WebContentsUserData<TorTabHelper> {
+ public:
+  // Create TorTabHelper for a WebContents
+  static void CreateForWebContents(content::WebContents* web_contents,
+                                   bool is_tor_tab = false);
+
+  // Set whether this is a Tor tab
+  void SetIsTorTab(bool is_tor_tab);
+  
+  // Check if this is a Tor tab
+  bool IsTorTab() const;
+
+  // WebContentsObserver overrides
+  void DidStartNavigation(
+      content::NavigationHandle* navigation_handle) override;
+  void DidFinishNavigation(
+      content::NavigationHandle* navigation_handle) override;
+  void WebContentsDestroyed() override;
+
+ private:
+  explicit TorTabHelper(content::WebContents* web_contents);
+  ~TorTabHelper() override;
+  
+  friend class content::WebContentsUserData<TorTabHelper>;
+
+  void ConfigureTorProxy();
+  void DisableWebRTC();
+
+  bool is_tor_tab_;
+  
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_TOR_TOR_TAB_HELPER_H_

