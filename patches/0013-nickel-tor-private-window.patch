@@ -0,0 +1,128 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_NICKEL_TOR_TOR_CONTROLLER_H_
+#define CHROME_BROWSER_NICKEL_TOR_TOR_CONTROLLER_H_
+
+#include <string>
+#include <vector>
+
+#include "base/base64.h"
+#include "base/files/file_path.h"
+#include "base/no_destructor.h"
+#include "base/observer_list.h"
+#include "base/process/process.h"
+#include "net/proxy_resolution/proxy_server.h"
+
+namespace nickel {
+
+// Tor connection state
+enum class TorState {
+  kNotInitialized,
+  kStopped,
+  kStarting,
+  kRunning,
+  kStopping,
+  kError
+};
+
+// Observer interface for Tor events
+class TorObserver {
+ public:
+  virtual ~TorObserver() = default;
+  
+  virtual void OnTorStarted() {}
+  virtual void OnTorStopped() {}
+  virtual void OnTorNewIdentity() {}
+  virtual void OnTorCircuitEstablished() {}
+  virtual void OnTorError(const std::string& error) {}
+};
+
+// Main controller for Tor integration
class TorController {
+ public:
+  // Returns the singleton instance
+  static TorController* GetInstance();
+
+  // Initialize Tor (find executable, create config)
+  void Initialize();
+  
+  // Shutdown Tor and cleanup
+  void Shutdown();
+
+  // Start Tor process
+  bool Start();
+  
+  // Stop Tor process
+  void Stop();
+
+  // Request new Tor circuit (new identity)
+  void NewIdentity();
+
+  // Get current state
+  TorState GetState() const;
+  
+  // Check if Tor is running
+  bool IsRunning() const;
+
+  // Get SOCKS proxy port
+  int GetSocksPort() const;
+  
+  // Get proxy server configuration
+  net::ProxyServer GetProxyServer() const;
+
+  // Add/remove observer
+  void AddObserver(TorObserver* observer);
+  void RemoveObserver(TorObserver* observer);
+
+ private:
+  TorController();
+  ~TorController();
+  
+  friend class base::NoDestructor<TorController>;
+
+  bool FindTorExecutable();
+  bool CreateTorConfig();
+  bool LaunchTorProcess();
+  bool WaitForTorReady();
+  bool CheckTorReady();
+  std::string SendControlCommand(const std::string& command);
+  std::string GenerateControlPassword();
+  std::string HashControlPassword(const std::string& password);
+
+  TorState state_;
+  int socks_port_;
+  int control_port_;
+  
+  base::FilePath tor_executable_;
+  base::FilePath config_dir_;
+  base::FilePath config_file_;
+  std::string control_password_;
+  
+  base::Process process_;
+  
+  base::ObserverList<TorObserver> observers_;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_TOR_TOR_CONTROLLER_H_

diff --git a/chrome/browser/nickel/tor/tor_tab_helper.cc b/chrome/browser/nickel/tor/tor_tab_helper.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/chrome/browser/nickel/tor/tor_tab_helper.cc
@@ -0,0 +1,156 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/nickel/tor/tor_tab_helper.h"
+
+#include "chrome/browser/nickel/tor/tor_controller.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents.h"
+#include "net/proxy_resolution/proxy_config.h"
+#include "net/proxy_resolution/proxy_config_service.h"
+#include "net/url_request/url_request_context.h"
+#include "net/url_request/url_request_context_getter.h"
+
+namespace nickel {
+
+TorTabHelper::TorTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<TorTabHelper>(*web_contents),
+      is_tor_tab_(false) {}
+
+TorTabHelper::~TorTabHelper() = default;
+
+// static
+void TorTabHelper::CreateForWebContents(content::WebContents* web_contents,
+                                        bool is_tor_tab) {
+  if (FromWebContents(web_contents)) {
+    return;
+  }
+  
+  web_contents->SetUserData(
+      UserDataKey(),
+      base::WrapUnique(new TorTabHelper(web_contents)));
+  
+  auto* helper = FromWebContents(web_contents);
+  if (helper) {
+    helper->SetIsTorTab(is_tor_tab);
+  }
+}
+
+void TorTabHelper::SetIsTorTab(bool is_tor_tab) {
+  is_tor_tab_ = is_tor_tab;
+  
+  if (is_tor_tab_) {
+    // Ensure Tor is running
+    auto* tor_controller = TorController::GetInstance();
+    if (!tor_controller->IsRunning()) {
+      tor_controller->Start();
+    }
+    
+    // Configure this tab to use Tor proxy
+    ConfigureTorProxy();
+    
+    // Disable WebRTC for this tab
+    DisableWebRTC();
+    
+    VLOG(1) << "Nickel Tor: Tab configured as Tor tab";
+  }
+}
+
+bool TorTabHelper::IsTorTab() const {
+  return is_tor_tab_;
+}
+
+void TorTabHelper::ConfigureTorProxy() {
+  auto* tor_controller = TorController::GetInstance();
+  if (!tor_controller->IsRunning()) {
+    return;
+  }
+  
+  // Get Tor proxy server
+  net::ProxyServer tor_proxy = tor_controller->GetProxyServer();
+  
+  // Configure proxy for this WebContents
+  // This is simplified - actual implementation would use proper proxy configuration
+  VLOG(1) << "Nickel Tor: Configuring proxy " << tor_proxy.ToURI();
+}
+
+void TorTabHelper::DisableWebRTC() {
+  // Disable WebRTC for Tor tabs to prevent IP leaks
+  content::WebContents* web_contents = GetWebContents();
+  if (!web_contents) {
+    return;
+  }
+  
+  // Set WebRTC disabled preference for this tab
+  // This is simplified - actual implementation would use proper WebRTC control
+  VLOG(1) << "Nickel Tor: WebRTC disabled for Tor tab";
+}
+
+void TorTabHelper::DidStartNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!is_tor_tab_) {
+    return;
+  }
+  
+  // Log navigation for transparency
+  VLOG(1) << "Nickel Tor: Navigation started to " 
+          << navigation_handle->GetURL().spec();
+}
+
+void TorTabHelper::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!is_tor_tab_) {
+    return;
+  }
+  
+  if (navigation_handle->HasCommitted() && !navigation_handle->IsErrorPage()) {
+    // Show Tor circuit info to user
+    VLOG(1) << "Nickel Tor: Navigation finished to "
+            << navigation_handle->GetURL().spec();
+  }
+}
+
+void TorTabHelper::WebContentsDestroyed() {
+  // Cleanup if this was a Tor tab
+  if (is_tor_tab_) {
+    VLOG(1) << "Nickel Tor: Tor tab destroyed";
+  }
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(TorTabHelper)
+
+}  // namespace nickel

