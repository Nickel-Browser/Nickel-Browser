+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/memory/singleton.h"
+#include "base/timer/timer.h"
+#include "chrome/browser/nickel/adblock/filter_engine.h"
+
+namespace nickel {
+
+// Filter list information
+struct FilterList {
+  std::string id;
+  std::string name;
+  std::string url;
+  bool enabled = false;
+  std::string group;
+  std::string last_updated;
+  size_t rule_count = 0;
+};
+
+// Main controller for Nickel's ad-blocking system
+class AdblockController {
+ public:
+  // Returns the singleton instance
+  static AdblockController* GetInstance();
+
+  // Initialize the ad-block system
+  void Initialize();
+  
+  // Shutdown the ad-block system
+  void Shutdown();
+
+  // Enable/disable ad-blocking
+  bool IsEnabled() const;
+  void SetEnabled(bool enabled);
+
+  // Cosmetic filtering
+  bool IsCosmeticFilteringEnabled() const;
+  void SetCosmeticFilteringEnabled(bool enabled);
+
+  // Scriptlet injection (anti-adblock bypass)
+  bool IsScriptletInjectionEnabled() const;
+  void SetScriptletInjectionEnabled(bool enabled);
+
+  // URL tracking parameter stripping
+  bool ShouldStripTrackingParams() const;
+  void SetStripTrackingParams(bool enabled);
+
+  // Get the filter engine
+  FilterEngine* GetFilterEngine();
+
+  // Blocked request statistics
+  uint64_t GetBlockedCount() const;
+  void IncrementBlockedCount();
+  void ResetBlockedCount();
+
+  // Get filter lists
+  const std::vector<FilterList>& GetFilterLists() const { return filter_lists_; }
+
+ private:
+  AdblockController();
+  ~AdblockController();
+  
+  friend struct base::DefaultSingletonTraits<AdblockController>;
+
+  void LoadFilterLists();
+  void ScheduleUpdates();
+  void UpdateFilterLists();
+  void DownloadFilterList(const FilterList& list);
+
+  bool enabled_;
+  bool cosmetic_filtering_enabled_;
+  bool scriptlet_injection_enabled_;
+  bool strip_tracking_params_;
+  uint64_t blocked_count_;
+  
+  std::unique_ptr<FilterEngine> filter_engine_;
+  std::vector<FilterList> filter_lists_;
+  base::RepeatingTimer update_timer_;
+};
+
+}  // namespace nickel
