+++ b/chrome/browser/nickel/adblock/filter_engine.cc
@@ -0,0 +1,456 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+// This file implements a uBlock Origin-compatible filtering engine
+// optimized for native integration with Chromium.
+
+#include "chrome/browser/nickel/adblock/filter_engine.h"
+
+#include <algorithm>
+#include <cstring>
+#include <regex>
+#include <utility>
+
+#include "base/logging.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+#include "url/gurl.h"
+
+namespace nickel {
+
+namespace {
+
+// Tracking parameters to strip from URLs
+const char* kTrackingParams[] = {
+    "utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content",
+    "utm_cid", "utm_reader", "utm_viz_id", "utm_pubreferrer", "utm_swu",
+    "fbclid", "gclid", "gclsrc", "dclid", "gbraid", "wbraid", "msclkid",
+    "mc_cid", "mc_eid", "_openstat", "yclid", "twclid", "igshid", "s_cid",
+    "ref_src", "ref_url", "rb_clickid", "oly_enc_id", "oly_anon_id",
+    "vero_id", "_hsenc", "_hsmi", "__hstc", "__hsfp", "hsCtaTracking",
+    "mkt_tok", "trk_contact", "trk_msg", "trk_module", "trk_sid",
+    "itm_source", "itm_medium", "itm_campaign", "itm_term", "itm_content"
+};
+
+// Convert resource type to string for filter matching
+const char* ResourceTypeToString(ResourceType type) {
+  switch (type) {
+    case RESOURCE_TYPE_DOCUMENT:
+      return "document";
+    case RESOURCE_TYPE_SUBDOCUMENT:
+      return "subdocument";
+    case RESOURCE_TYPE_STYLESHEET:
+      return "stylesheet";
+    case RESOURCE_TYPE_SCRIPT:
+      return "script";
+    case RESOURCE_TYPE_IMAGE:
+      return "image";
+    case RESOURCE_TYPE_FONT:
+      return "font";
+    case RESOURCE_TYPE_MEDIA:
+      return "media";
+    case RESOURCE_TYPE_XMLHTTPREQUEST:
+      return "xmlhttprequest";
+    case RESOURCE_TYPE_PING:
+      return "ping";
+    case RESOURCE_TYPE_WEBSOCKET:
+      return "websocket";
+    case RESOURCE_TYPE_OTHER:
+    default:
+      return "other";
+  }
+}
+
+}  // namespace

+FilterEngine::FilterEngine() = default;
+
+FilterEngine::~FilterEngine() = default;
+
+void FilterEngine::Initialize() {
+  VLOG(1) << "Nickel FilterEngine: Initializing...";
+  
+  // Load bundled filter lists
+  LoadBundledFilters();
+  
+  // Compile filter rules
+  CompileFilters();
+  
+  VLOG(1) << "Nickel FilterEngine: Loaded " << network_filters_.size() 
+          << " network filters, " << cosmetic_filters_.size() 
+          << " cosmetic filters";
+}
+
+void FilterEngine::Shutdown() {
+  network_filters_.clear();
+  cosmetic_filters_.clear();
+  scriptlet_rules_.clear();
+}
+
+FilterResult FilterEngine::ShouldBlock(const GURL& url,
+                                        const GURL& initiator,
+                                        ResourceType resource_type) {
+  FilterResult result;
+  result.blocked = false;
+  
+  if (!url.is_valid()) {
+    return result;
+  }
+  
+  // Check network filters
+  for (const auto& filter : network_filters_) {
+    if (MatchesFilter(filter, url, initiator, resource_type)) {
+      result.blocked = true;
+      result.filter = filter.raw_rule;
+      result.reason = FilterReason::NETWORK_FILTER;
+      
+      // Check for redirect rule
+      if (!filter.redirect.empty()) {
+        result.redirect = GURL(filter.redirect);
+      }
+      
+      return result;
+    }
+  }
+  
+  // Check host-based blocks
+  std::string host = url.host();
+  if (blocked_hosts_.find(host) != blocked_hosts_.end()) {
+    result.blocked = true;
+    result.filter = host;
+    result.reason = FilterReason::HOST_BLOCK;
+    return result;
+  }
+  
+  return result;
+}
+
+std::vector<CosmeticFilter> FilterEngine::GetCosmeticFilters(
+    const GURL& url) {
+  std::vector<CosmeticFilter> result;
+  
+  std::string domain = url.host();
+  
+  for (const auto& filter : cosmetic_filters_) {
+    if (MatchesDomain(filter.domains, domain)) {
+      result.push_back(filter);
+    }
+  }
+  
+  return result;
+}
+
+std::vector<ScriptletRule> FilterEngine::GetScriptletRules(
+    const GURL& url) {
+  std::vector<ScriptletRule> result;
+  
+  std::string domain = url.host();
+  
+  for (const auto& rule : scriptlet_rules_) {
+    if (MatchesDomain(rule.domains, domain)) {
+      result.push_back(rule);
+    }
+  }
+  
+  return result;
+}
+
+GURL FilterEngine::StripTrackingParameters(const GURL& url) {
+  if (!url.is_valid() || !url.has_query()) {
+    return url;
+  }
+  
+  std::string query = url.query();
+  std::vector<std::string> params = base::SplitString(
+      query, "&", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+  
+  std::vector<std::string> cleaned_params;
+  bool modified = false;
+  
+  for (const auto& param : params) {
+    size_t eq_pos = param.find('=');
+    std::string key = (eq_pos != std::string::npos) 
+        ? param.substr(0, eq_pos) : param;
+    
+    bool is_tracking = false;
+    for (const auto* tracking : kTrackingParams) {
+      if (base::EqualsCaseInsensitiveASCII(key, tracking)) {
+        is_tracking = true;
+        modified = true;
+        break;
+      }
+    }
+    
+    if (!is_tracking) {
+      cleaned_params.push_back(param);
+    }
+  }
+  
+  if (!modified) {
+    return url;
+  }
+  
+  std::string new_query = base::JoinString(cleaned_params, "&");
+  
+  GURL::Replacements replacements;
+  replacements.SetQueryStr(new_query);
+  return url.ReplaceComponents(replacements);
+}
+
+void FilterEngine::LoadBundledFilters() {
+  // Load EasyList patterns (simplified for this patch)
+  // In production, these would be loaded from files
+  
+  // Common ad network patterns
+  const char* ad_patterns[] = {
+      "||doubleclick.net^",
+      "||googleadservices.com^",
+      "||googlesyndication.com^",
+      "||google-analytics.com^",
+      "||facebook.com/tr/*",
+      "||connect.facebook.net/*/fbevents.js",
+      "||amazon-adsystem.com^",
+      "||adsystem.amazon.com^",
+      "||ads.yahoo.com^",
+      "||advertising.com^",
+      "||adsrvr.org^",
+      "||adnxs.com^",
+      "||rubiconproject.com^",
+      "||openx.net^",
+      "||pubmatic.com^",
+      "||criteo.com^",
+      "||casalemedia.com^",
+      "||adsafeprotected.com^",
+      "||moatads.com^",
+      "||scorecardresearch.com^",
+      "||quantserve.com^",
+      "||googletagmanager.com^",
+      "||googletagservices.com^",
+      "||google.com/pagead/*",
+      "||youtube.com/pagead/*",
+      "||youtube.com/api/stats/ads*",
+      "||googlevideo.com/videoplayback*&ad",
+  };
+  
+  for (const auto* pattern : ad_patterns) {
+    NetworkFilter filter;
+    filter.raw_rule = pattern;
+    filter.is_exception = false;
+    filter.is_important = false;
+    ParseFilterRule(pattern, &filter);
+    network_filters_.push_back(std::move(filter));
+  }
+  
+  // Add blocked hosts
+  const char* blocked_hosts[] = {
+      "googleads.g.doubleclick.net",
+      "pagead2.googlesyndication.com",
+      "ads.google.com",
+      "adservice.google.com",
+      "static.doubleclick.net",
+      "m.doubleclick.net",
+      "mediavisor.doubleclick.net",
+      "ads.yahoo.com",
+      "advertising.yahoo.com",
+      "analytics.yahoo.com",
+      "gemini.yahoo.com",
+      "ads.facebook.com",
+      "an.facebook.com",
+      "pixel.facebook.com",
+      "ads.twitter.com",
+      "analytics.twitter.com",
+      "ads.pinterest.com",
+      "analytics.pinterest.com",
+      "ads.reddit.com",
+      "d.reddit.com",
+      "rereddit.com",
+      "events.redditmedia.com",
+      "ads.tiktok.com",
+      "analytics.tiktok.com",
+      "ads.snapchat.com",
+      "tr.snapchat.com",
+  };
+  
+  for (const auto* host : blocked_hosts) {
+    blocked_hosts_.insert(host);
+  }
+}
+
+void FilterEngine::CompileFilters() {
+  // Compile filter rules for faster matching
+  // This would optimize the filter matching in production
+  VLOG(1) << "Nickel FilterEngine: Compiling " << network_filters_.size() 
+          << " network filters";
+}
+
+bool FilterEngine::MatchesFilter(const NetworkFilter& filter,
+                                  const GURL& url,
+                                  const GURL& initiator,
+                                  ResourceType resource_type) {
+  // Check URL pattern match
+  if (!MatchesUrlPattern(filter, url)) {
+    return false;
+  }
+  
+  // Check initiator domain restrictions
+  if (!filter.domains.empty() && initiator.is_valid()) {
+    if (!MatchesDomain(filter.domains, initiator.host())) {
+      return false;
+    }
+  }
+  
+  // Check resource type
+  if (!filter.resource_types.empty()) {
+    std::string type_str = ResourceTypeToString(resource_type);
+    bool type_matches = false;
+    for (const auto& type : filter.resource_types) {
+      if (type == type_str) {
+        type_matches = true;
+        break;
+      }
+    }
+    if (!type_matches) {
+      return false;
+    }
+  }
+  
+  return true;
+}
+
+bool FilterEngine::MatchesUrlPattern(const NetworkFilter& filter,
+                                      const GURL& url) {
+  const std::string& pattern = filter.url_pattern;
+  const std::string& url_str = url.spec();
+  
+  // Simple pattern matching (simplified for this patch)
+  // In production, this would use more sophisticated matching
+  
+  if (pattern.empty()) {
+    return false;
+  }
+  
+  // Handle ||domain^ pattern (match domain and subdomains)
+  if (pattern.substr(0, 2) == "||") {
+    std::string domain = pattern.substr(2);
+    // Remove trailing ^
+    if (!domain.empty() && domain.back() == '^') {
+      domain.pop_back();
+    }
+    
+    std::string host = url.host();
+    // Check if host equals or ends with domain
+    if (host == domain) {
+      return true;
+    }
+    std::string suffix = "." + domain;
+    if (host.size() > suffix.size() && 
+        host.substr(host.size() - suffix.size()) == suffix) {
+      return true;
+    }
+    return false;
+  }
+  
+  // Handle |pattern (match at beginning)
+  if (pattern[0] == '|') {
+    std::string search = pattern.substr(1);
+    return url_str.find(search) == 0;
+  }
+  
+  // Simple substring match
+  return url_str.find(pattern) != std::string::npos;
+}
+
+bool FilterEngine::MatchesDomain(const std::vector<std::string>& domains,
+                                  const std::string& domain) {
+  if (domains.empty()) {
+    return true;
+  }
+  
+  for (const auto& d : domains) {
+    // Handle negation (~domain)
+    if (!d.empty() && d[0] == '~') {
+      std::string negated = d.substr(1);
+      if (domain == negated || domain.size() > negated.size() + 1 &&
+          domain.substr(domain.size() - negated.size() - 1) == "." + negated) {
+        return false;
+      }
+    } else if (domain == d || (domain.size() > d.size() + 1 &&
+               domain.substr(domain.size() - d.size() - 1) == "." + d)) {
+      return true;
+    }
+  }
+  
+  return false;
+}
+
+void FilterEngine::ParseFilterRule(const std::string& rule,
+                                    NetworkFilter* filter) {
+  // Parse filter rule options
+  size_t options_pos = rule.find('$');
+  if (options_pos != std::string::npos) {
+    std::string options = rule.substr(options_pos + 1);
+    std::vector<std::string> option_list = base::SplitString(
+        options, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    
+    for (const auto& opt : option_list) {
+      if (opt == "important") {
+        filter->is_important = true;
+      } else if (opt.substr(0, 4) == "domain") {
+        // Parse domain restrictions
+        size_t eq_pos = opt.find('=');
+        if (eq_pos != std::string::npos) {
+          std::string domains = opt.substr(eq_pos + 1);
+          filter->domains = base::SplitString(
+              domains, "|", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+        }
+      } else if (opt.substr(0, 4) == "type") {
+        // Parse resource type restrictions
+        size_t eq_pos = opt.find('=');
+        if (eq_pos != std::string::npos) {
+          std::string types = opt.substr(eq_pos + 1);
+          filter->resource_types = base::SplitString(
+              types, "|", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+        }
+      } else if (opt.substr(0, 8) == "redirect") {
+        // Parse redirect target
+        size_t eq_pos = opt.find('=');
+        if (eq_pos != std::string::npos) {
+          filter->redirect = opt.substr(eq_pos + 1);
+        }
+      }
+    }
+    
+    filter->url_pattern = rule.substr(0, options_pos);
+  } else {
+    filter->url_pattern = rule;
+  }
+}
+
+}  // namespace nickel

