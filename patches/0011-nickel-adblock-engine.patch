+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_NICKEL_ADBLOCK_FILTER_ENGINE_H_
+#define CHROME_BROWSER_NICKEL_ADBLOCK_FILTER_ENGINE_H_
+
+#include <memory>
+#include <optional>
+#include <set>
+#include <string>
+#include <unordered_map>
+#include <unordered_set>
+#include <vector>
+
+#include "url/gurl.h"
+
+namespace nickel {
+
+// Resource types for filter matching
+enum ResourceType {
+  RESOURCE_TYPE_DOCUMENT,
+  RESOURCE_TYPE_SUBDOCUMENT,
+  RESOURCE_TYPE_STYLESHEET,
+  RESOURCE_TYPE_SCRIPT,
+  RESOURCE_TYPE_IMAGE,
+  RESOURCE_TYPE_FONT,
+  RESOURCE_TYPE_MEDIA,
+  RESOURCE_TYPE_XMLHTTPREQUEST,
+  RESOURCE_TYPE_PING,
+  RESOURCE_TYPE_WEBSOCKET,
+  RESOURCE_TYPE_OTHER
+};
+
+// Reason for blocking
+enum class FilterReason {
+  NOT_BLOCKED,
+  NETWORK_FILTER,
+  HOST_BLOCK,
+  COSMETIC_FILTER,
+  SCRIPTLET
+};
+
+// Result of filter check
+struct FilterResult {
+  bool blocked = false;
+  FilterReason reason = FilterReason::NOT_BLOCKED;
+  std::string filter;
+  std::optional<GURL> redirect;
+};
+
+// Network filter rule
+struct NetworkFilter {
+  std::string raw_rule;
+  std::string url_pattern;
+  std::vector<std::string> domains;
+  std::vector<std::string> resource_types;
+  std::string redirect;
+  bool is_exception = false;
+  bool is_important = false;
+};
+
+// Cosmetic filter (element hiding)
+struct CosmeticFilter {
+  std::string selector;
+  std::vector<std::string> domains;
+  std::string procedural;
+};
+
+// Scriptlet rule (JavaScript injection)
+struct ScriptletRule {
+  std::string name;
+  std::vector<std::string> args;
+  std::vector<std::string> domains;
+};
+
+// Main filtering engine
+class FilterEngine {
+ public:
+  FilterEngine();
+  ~FilterEngine();
+
+  // Initialize the filter engine
+  void Initialize();
+  
+  // Shutdown the filter engine
+  void Shutdown();
+
+  // Check if a request should be blocked
+  FilterResult ShouldBlock(const GURL& url,
+                           const GURL& initiator,
+                           ResourceType resource_type);
+
+  // Get cosmetic filters for a page
+  std::vector<CosmeticFilter> GetCosmeticFilters(const GURL& url);
+
+  // Get scriptlet rules for a page
+  std::vector<ScriptletRule> GetScriptletRules(const GURL& url);
+
+  // Strip tracking parameters from URL
+  GURL StripTrackingParameters(const GURL& url);
+
+  // Add a custom filter rule
+  void AddFilter(const std::string& rule);
+
+  // Remove a custom filter rule
+  void RemoveFilter(const std::string& rule);
+
+  // Get filter statistics
+  size_t GetNetworkFilterCount() const { return network_filters_.size(); }
+  size_t GetCosmeticFilterCount() const { return cosmetic_filters_.size(); }
+  size_t GetScriptletRuleCount() const { return scriptlet_rules_.size(); }
+
+ private:
+  void LoadBundledFilters();
+  void CompileFilters();
+  
+  bool MatchesFilter(const NetworkFilter& filter,
+                     const GURL& url,
+                     const GURL& initiator,
+                     ResourceType resource_type);
+  bool MatchesUrlPattern(const NetworkFilter& filter, const GURL& url);
+  bool MatchesDomain(const std::vector<std::string>& domains,
+                     const std::string& domain);
+  void ParseFilterRule(const std::string& rule, NetworkFilter* filter);
+
+  std::vector<NetworkFilter> network_filters_;
+  std::vector<CosmeticFilter> cosmetic_filters_;
+  std::vector<ScriptletRule> scriptlet_rules_;
+  std::unordered_set<std::string> blocked_hosts_;
+  std::unordered_set<std::string> custom_filters_;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_ADBLOCK_FILTER_ENGINE_H_

