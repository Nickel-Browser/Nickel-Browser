index 1234567..abcdefg 100644
--- a/chrome/browser/net/chrome_network_delegate.cc
+++ b/chrome/browser/net/chrome_network_delegate.cc
@@ -50,6 +50,10 @@
 #include "services/network/public/mojom/network_context.mojom.h"
 #include "url/gurl.h"
 
+// Nickel: Ad-block integration
+#include "chrome/browser/nickel/adblock/adblock_controller.h"
+#include "chrome/browser/nickel/adblock/filter_engine.h"
+
 #if BUILDFLAG(IS_ANDROID)
 #include "chrome/browser/android/google_play_services_availability.h"
 #endif
@@ -200,6 +204,87 @@ int ChromeNetworkDelegate::OnBeforeURLRequest(
     return net::ERR_BLOCKED_BY_ADMINISTRATOR;
   }
 
+  // ===== NICKEL AD-BLOCK CHECK =====
+  // Check if request should be blocked by ad-block engine
+  auto* adblock_controller = nickel::AdblockController::GetInstance();
+  if (adblock_controller && adblock_controller->IsEnabled()) {
+    auto* filter_engine = adblock_controller->GetFilterEngine();
+    if (filter_engine) {
+      // Get request details
+      const GURL& url = request->url();
+      const GURL& initiator = request->initiator().has_value() 
+          ? request->initiator().value().GetURL() : GURL();
+      
+      // Determine resource type
+      nickel::ResourceType resource_type = nickel::RESOURCE_TYPE_OTHER;
+      switch (request->resource_type()) {
+        case network::mojom::ResourceType::kMainFrame:
+          resource_type = nickel::RESOURCE_TYPE_DOCUMENT;
+          break;
+        case network::mojom::ResourceType::kSubFrame:
+          resource_type = nickel::RESOURCE_TYPE_SUBDOCUMENT;
+          break;
+        case network::mojom::ResourceType::kStylesheet:
+          resource_type = nickel::RESOURCE_TYPE_STYLESHEET;
+          break;
+        case network::mojom::ResourceType::kScript:
+          resource_type = nickel::RESOURCE_TYPE_SCRIPT;
+          break;
+        case network::mojom::ResourceType::kImage:
+          resource_type = nickel::RESOURCE_TYPE_IMAGE;
+          break;
+        case network::mojom::ResourceType::kFontResource:
+          resource_type = nickel::RESOURCE_TYPE_FONT;
+          break;
+        case network::mojom::ResourceType::kMedia:
+          resource_type = nickel::RESOURCE_TYPE_MEDIA;
+          break;
+        case network::mojom::ResourceType::kXhr:
+          resource_type = nickel::RESOURCE_TYPE_XMLHTTPREQUEST;
+          break;
+        case network::mojom::ResourceType::kPing:
+          resource_type = nickel::RESOURCE_TYPE_PING;
+          break;
+        default:
+          resource_type = nickel::RESOURCE_TYPE_OTHER;
+          break;
+      }
+      
+      // Check if should block
+      nickel::FilterResult result = filter_engine->ShouldBlock(
+          url, initiator, resource_type);
+      
+      if (result.blocked) {
+        VLOG(1) << "Nickel Ad-Block: Blocked " << url.spec()
+                << " (filter: " << result.filter << ")";
+        
+        // Increment blocked counter for stats
+        adblock_controller->IncrementBlockedCount();
+        
+        return net::ERR_BLOCKED_BY_CLIENT;
+      }
+      
+      // Check for redirect
+      if (result.redirect.has_value()) {
+        *new_url = result.redirect.value();
+        return net::OK;
+      }
+      
+      // Strip tracking parameters if enabled
+      if (adblock_controller->ShouldStripTrackingParams()) {
+        GURL stripped_url = filter_engine->StripTrackingParameters(url);
+        if (stripped_url != url) {
+          *new_url = stripped_url;
+          return net::OK;
+        }
+      }
+    }
+  }
+  // ===== END NICKEL AD-BLOCK CHECK =====
+
   // TODO(crbug.com/40821091): Remove this once the experiment is complete.
   if (base::FeatureList::IsEnabled(
           features::kTriggerNetworkDataMigrationToPolicyPath)) {

