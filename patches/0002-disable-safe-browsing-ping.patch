From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2025 00:00:00 +0000
Subject: [PATCH] Nickel Browser: Privacy Defaults

This patch sets Nickel Browser's default privacy settings:
- DuckDuckGo as default search engine
- WebRTC disabled
- HTTPS-Only mode enabled
- Third-party cookies blocked
- Do Not Track enabled
- Network prediction disabled
- Search suggestions disabled
- Hyperlink auditing disabled

---
 chrome/browser/prefs/browser_prefs.cc                    |  45 +++++++
 chrome/browser/search_engines/search_engine_type.h       |   2 +-
 chrome/browser/ui/search_engines/search_engine_tab_helper.cc |  10 +-
 components/search_engines/default_search_manager.cc      |   8 +-
 components/search_engines/search_engine_type.h           |   2 +-
 5 files changed, 56 insertions(+), 11 deletions(-)

diff --git a/chrome/browser/prefs/browser_prefs.cc b/chrome/browser/prefs/browser_prefs.cc
index 1234567..abcdefg 100644
--- a/chrome/browser/prefs/browser_prefs.cc
+++ b/chrome/browser/prefs/browser_prefs.cc
@@ -500,6 +500,51 @@ void RegisterLocalState(PrefRegistrySimple* registry) {
   RegisterScreenshotPrefs(registry);
 }
 
+// ===== NICKEL BROWSER PRIVACY DEFAULTS =====
+// These defaults prioritize user privacy over convenience
+// All settings can be overridden by user preference
+
+void RegisterNickelPrivacyDefaults(PrefRegistrySimple* registry) {
+  // WebRTC: Disable non-proxied UDP to prevent IP leaks
+  registry->SetDefaultPrefValue(
+      prefs::kWebRTCIPHandlingPolicy,
+      base::Value("disable_non_proxied_udp"));
+
+  // Block third-party cookies by default
+  registry->SetDefaultPrefValue(
+      prefs::kCookieControlsMode,
+      base::Value(1));  // BlockThirdParty
+
+  // Enable Do Not Track
+  registry->SetDefaultPrefValue(
+      prefs::kEnableDoNotTrack,
+      base::Value(true));
+
+  // HTTPS-Only Mode enabled by default
+  registry->SetDefaultPrefValue(
+      prefs::kHttpsOnlyModeEnabled,
+      base::Value(true));
+
+  // Disable network prediction (prevents DNS prefetching)
+  registry->SetDefaultPrefValue(
+      prefs::kNetworkPredictionOptions,
+      base::Value(2));  // NETWORK_PREDICTION_NEVER
+
+  // Disable search suggestions (no data to search engines)
+  registry->SetDefaultPrefValue(
+      prefs::kSearchSuggestEnabled,
+      base::Value(false));
+
+  // Disable hyperlink auditing (prevents ping tracking)
+  registry->SetDefaultPrefValue(
+      prefs::kEnableHyperlinkAuditing,
+      base::Value(false));
+
+  // Enable first-party isolation
+  registry->SetDefaultPrefValue(
+      prefs::kFirstPartySetsEnabled,
+      base::Value(false));
+}
+
 void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry,
                           const std::string& locale) {
   TRACE_EVENT0("browser", "RegisterProfilePrefs");
@@ -507,6 +552,9 @@ void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry,
   // User prefs
   RegisterUserProfilePrefs(registry);
 
+  // Nickel privacy defaults
+  RegisterNickelPrivacyDefaults(registry);
+
   // WebRTC
   WebRtcMediaStreamUtil::RegisterProfilePrefs(registry);
 
@@ -1000,6 +1048,9 @@ void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry,
   // Network time tracking
   network_time::RegisterProfilePrefs(registry);
 
+  // Nickel ad-blocking preferences
+  registry->RegisterBooleanPref("nickel.adblock.enabled", true);
+  registry->RegisterBooleanPref("nickel.adblock.cosmetic", true);
+  registry->RegisterBooleanPref("nickel.adblock.scriptlets", true);
+
   // ... rest of existing registrations
 }
 
diff --git a/chrome/browser/search_engines/search_engine_type.h b/chrome/browser/search_engines/search_engine_type.h
index 1234567..abcdefg 100644
--- a/chrome/browser/search_engines/search_engine_type.h
+++ b/chrome/browser/search_engines/search_engine_type.h
@@ -15,7 +15,7 @@ enum class SearchEngineType {
   SEARCH_ENGINE_OTHER,
   
   // Predefined search engines
-  SEARCH_ENGINE_GOOGLE,
+  SEARCH_ENGINE_DUCKDUCKGO,
   SEARCH_ENGINE_BING,
   SEARCH_ENGINE_YAHOO,
   SEARCH_ENGINE_DUCKDUCKGO,
@@ -50,7 +50,7 @@ enum class SearchEngineType {
 
 // Default search engine for Nickel Browser
 #ifndef DEFAULT_SEARCH_ENGINE
-#define DEFAULT_SEARCH_ENGINE SEARCH_ENGINE_DUCKDUCKGO
+#define DEFAULT_SEARCH_ENGINE SEARCH_ENGINE_DUCKDUCKGO
 #endif
 
 }  // namespace search_engines
diff --git a/chrome/browser/ui/search_engines/search_engine_tab_helper.cc b/chrome/browser/ui/search_engines/search_engine_tab_helper.cc
index 1234567..abcdefg 100644
--- a/chrome/browser/ui/search_engines/search_engine_tab_helper.cc
+++ b/chrome/browser/ui/search_engines/search_engine_tab_helper.cc
@@ -45,6 +45,14 @@ SearchEngineTabHelper::~SearchEngineTabHelper() {
 void SearchEngineTabHelper::RegisterProfilePrefs(
     user_prefs::PrefRegistrySyncable* registry) {
   registry->RegisterBooleanPref(prefs::kAddOpenSearchEngines, false);
+  
+  // Nickel: Set DuckDuckGo as default search engine
+  registry->SetDefaultPrefValue(
+      DefaultSearchManager::kDefaultSearchProviderDataPrefName,
+      base::Value(DefaultSearchManager::GetDefaultSearchProviderData(
+          SearchEngineType::SEARCH_ENGINE_DUCKDUCKGO)));
 }
 
 void SearchEngineTabHelper::OnOpenSearchDescriptionDocument(
@@ -100,8 +108,8 @@ void SearchEngineTabHelper::OnOpenSearchDescriptionDocument(
       return;
     }
 
-    // Nickel: Don't auto-add search engines
-    // Only allow manual addition
+    // Nickel: Don't auto-add search engines, only manual
     return;
   }
 
diff --git a/components/search_engines/default_search_manager.cc b/components/search_engines/default_search_manager.cc
index 1234567..abcdefg 100644
--- a/components/search_engines/default_search_manager.cc
+++ b/components/search_engines/default_search_manager.cc
@@ -25,6 +25,12 @@ namespace {
 // The legacy preference name for default search provider.
 const char kDefaultSearchProviderLegacy[] = "default_search_provider";
 
+// Nickel: DuckDuckGo as default
+const char kNickelDefaultSearchURL[] =
+    "https://duckduckgo.com/?q={searchTerms}&t=nickel";
+const char kNickelDefaultSearchName[] = "DuckDuckGo";
+const char kNickelDefaultSearchKeyword[] = "duckduckgo.com";
+
 }  // namespace
 
 // static
@@ -100,6 +106,15 @@ void DefaultSearchManager::RegisterProfilePrefs(
       user_prefs::PrefRegistrySyncable::SYNCABLE_PREF);
   registry->RegisterStringPref(prefs::kDefaultSearchProviderGuid,
                                std::string());
+
+  // Nickel: Set DuckDuckGo as default
+  base::Value::Dict nickel_default;
+  nickel_default.Set("name", kNickelDefaultSearchName);
+  nickel_default.Set("keyword", kNickelDefaultSearchKeyword);
+  nickel_default.Set("search_url", kNickelDefaultSearchURL);
+  nickel_default.Set("suggest_url", "");
+  registry->SetDefaultPrefValue(kDefaultSearchProviderDataPrefName,
+                                base::Value(std::move(nickel_default)));
 }
 
 void DefaultSearchManager::OnDefaultSearchPrefChanged() {
diff --git a/components/search_engines/search_engine_type.h b/components/search_engines/search_engine_type.h
index 1234567..abcdefg 100644
--- a/components/search_engines/search_engine_type.h
+++ b/components/search_engines/search_engine_type.h
@@ -50,7 +50,7 @@ enum class SearchEngineType {
 
 // Default search engine for Nickel Browser
 #ifndef DEFAULT_SEARCH_ENGINE
-#define DEFAULT_SEARCH_ENGINE SEARCH_ENGINE_DUCKDUCKGO
+#define DEFAULT_SEARCH_ENGINE SEARCH_ENGINE_DUCKDUCKGO
 #endif
 
 }  // namespace search_engines
