+++ b/chrome/browser/nickel/adblock/nickel_adblock_engine.cc
@@ -0,0 +1,168 @@
+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_engine.cc
+// Ad-blocking filter engine implementation.
+//
+// Current implementation: a minimal domain-tree matcher that handles the most
+// common EasyList rule patterns.  A full Adblock Plus / uBlock Origin
+// compatible parser is tracked in:
+//   https://github.com/Nickel-Browser/Nickel-Browser/issues/TODO
+
+#include "chrome/browser/nickel/adblock/nickel_adblock_engine.h"
+
+#include <algorithm>
+#include <sstream>
+#include <unordered_map>
+#include <unordered_set>
+
+#include "base/logging.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+#include "net/base/registry_controlled_domains/registry_controlled_domain.h"
+
+namespace nickel {
+namespace adblock {
+
+namespace {
+
+// Normalize a URL for matching (lowercase, strip fragment).
+std::string NormalizeURL(const GURL& url) {
+  GURL::Replacements reps;
+  reps.ClearRef();
+  return base::ToLowerASCII(url.ReplaceComponents(reps).spec());
+}
+
+// Extract the eTLD+1 from a URL for domain matching.
+std::string GetDomain(const GURL& url) {
+  return net::registry_controlled_domains::GetDomainAndRegistry(
+      url, net::registry_controlled_domains::EXCLUDE_PRIVATE_REGISTRIES);
+}
+
+// Parse a single EasyList filter rule.
+// Returns (pattern, is_exception, domain_anchor).
+struct ParsedRule {
+  std::string pattern;
+  bool is_exception   = false;
+  bool domain_anchor  = false;  // rule starts with ||
+  bool is_comment     = false;
+  bool is_element_hide = false;  // ## cosmetic rule (ignored here)
+};
+
+ParsedRule ParseRule(const std::string& raw) {
+  ParsedRule r;
+  if (raw.empty() || raw[0] == '!') {
+    r.is_comment = true;
+    return r;
+  }
+  if (raw.find("##") != std::string::npos ||
+      raw.find("#@#") != std::string::npos) {
+    r.is_element_hide = true;
+    return r;
+  }
+  std::string rule = raw;
+  if (base::StartsWith(rule, "@@")) {
+    r.is_exception = true;
+    rule = rule.substr(2);
+  }
+  if (base::StartsWith(rule, "||")) {
+    r.domain_anchor = true;
+    rule = rule.substr(2);
+  }
+  // Strip options (everything after $)
+  auto dollar = rule.find('$');
+  if (dollar != std::string::npos) {
+    rule = rule.substr(0, dollar);
+  }
+  r.pattern = base::ToLowerASCII(rule);
+  return r;
+}
+
+}  // namespace
+
+struct NickelAdBlockEngine::Impl {
+  // Domain-anchored block rules: if the request domain ends with any of these,
+  // the request is blocked.
+  std::unordered_set<std::string> blocked_domains;
+  // Exception rules: these override block rules.
+  std::unordered_set<std::string> exception_domains;
+  // Generic substring rules (slower path, applied after domain check).
+  std::vector<std::string> substring_rules;
+
+  size_t rule_count = 0;
+};
+
+NickelAdBlockEngine::NickelAdBlockEngine()
+    : impl_(std::make_unique<Impl>()) {}
+NickelAdBlockEngine::~NickelAdBlockEngine() = default;
+
+size_t NickelAdBlockEngine::LoadRules(const std::string& text) {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+
+  size_t loaded = 0;
+  std::istringstream stream(text);
+  std::string line;
+  while (std::getline(stream, line)) {
+    base::TrimWhitespaceASCII(line, base::TRIM_ALL, &line);
+    if (line.empty()) continue;
+
+    ParsedRule r = ParseRule(line);
+    if (r.is_comment || r.is_element_hide) continue;
+    if (r.pattern.empty()) continue;
+
+    if (r.domain_anchor) {
+      if (r.is_exception) {
+        impl_->exception_domains.insert(r.pattern);
+      } else {
+        impl_->blocked_domains.insert(r.pattern);
+      }
+    } else {
+      if (!r.is_exception) {
+        impl_->substring_rules.push_back(r.pattern);
+      }
+    }
+    ++loaded;
+  }
+  impl_->rule_count += loaded;
+  VLOG(1) << "NickelAdBlock: loaded " << loaded << " rules";
+  return loaded;
+}
+
+bool NickelAdBlockEngine::LoadBinary(const std::vector<uint8_t>& /*blob*/) {
+  // TODO: implement binary de-serialization.
+  return false;
+}
+
+std::vector<uint8_t> NickelAdBlockEngine::SerialiseRules() const {
+  // TODO: implement binary serialization.
+  return {};
+}
+
+FilterResult NickelAdBlockEngine::ShouldBlock(
+    const GURL& request_url,
+    const GURL& document_url,
+    RequestType /*type*/) const {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+
+  FilterResult result;
+  if (!request_url.is_valid()) return result;
+
+  const std::string req_domain = GetDomain(request_url);
+  const std::string req_url    = NormalizeURL(request_url);
+
+  // Exception check first (whitelist wins).
+  if (impl_->exception_domains.count(req_domain)) {
+    return result;  // allowed
+  }
+
+  // Domain-anchor block.
+  if (impl_->blocked_domains.count(req_domain)) {
+    result.blocked = true;
+    result.matched_rule = "||" + req_domain;
+    return result;
+  }
+
+  // Substring rules (slower).
+  for (const auto& pattern : impl_->substring_rules) {
+    if (req_url.find(pattern) != std::string::npos) {
+      result.blocked = true;
+      result.matched_rule = pattern;
+      return result;
+    }
+  }
+
+  return result;
+}
+
+size_t NickelAdBlockEngine::RuleCount() const {
+  return impl_->rule_count;
+}
+
+void NickelAdBlockEngine::Clear() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  impl_->blocked_domains.clear();
+  impl_->exception_domains.clear();
+  impl_->substring_rules.clear();
+  impl_->rule_count = 0;
+}
+
+}  // namespace adblock
+}  // namespace nickel
