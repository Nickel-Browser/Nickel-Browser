+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_throttle.h
+// URLLoaderThrottle that cancels requests matching the ad-block engine.
+
+#ifndef CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_THROTTLE_H_
+#define CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_THROTTLE_H_
+
+#include "third_party/blink/public/common/loader/url_loader_throttle.h"
+#include "url/gurl.h"
+
+namespace nickel {
+namespace adblock {
+
+// Installed into the renderer process via
+// ContentRendererClient::CreateURLLoaderThrottles().
+// Evaluates each network request against NickelAdBlockService before
+// the request is sent.
+class NickelAdBlockThrottle : public blink::URLLoaderThrottle {
+ public:
+  explicit NickelAdBlockThrottle(const GURL& document_url);
+  ~NickelAdBlockThrottle() override;
+
+  // blink::URLLoaderThrottle:
+  void WillStartRequest(network::ResourceRequest* request,
+                        bool* defer) override;
+  const char* NameForLogging() override;
+
+ private:
+  GURL document_url_;
+};
+
+}  // namespace adblock
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_THROTTLE_H_
