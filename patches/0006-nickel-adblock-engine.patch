+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_service.h
+// Browser-process singleton that owns the ad-block engine and manages
+// filter-list updates.
+
+#ifndef CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_SERVICE_H_
+#define CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_SERVICE_H_
+
+#include <memory>
+
+#include "base/memory/singleton.h"
+#include "chrome/browser/nickel/adblock/nickel_adblock_engine.h"
+
+namespace nickel {
+namespace adblock {
+
+class NickelAdBlockService {
+ public:
+  static NickelAdBlockService* GetInstance();
+
+  NickelAdBlockService(const NickelAdBlockService&) = delete;
+  NickelAdBlockService& operator=(const NickelAdBlockService&) = delete;
+
+  // Load bundled default filter lists (EasyList + EasyPrivacy).
+  // Called once on browser startup.
+  void LoadDefaultFilterLists();
+
+  // Hot-reload filter lists from disk (called after a background update).
+  void ReloadFilterLists(const std::string& filter_list_text);
+
+  // Returns true if |request_url| should be blocked.
+  bool ShouldBlock(const GURL& request_url,
+                   const GURL& document_url,
+                   RequestType type) const;
+
+  // Enable or disable the ad-block engine at runtime.
+  void SetEnabled(bool enabled);
+  bool IsEnabled() const;
+
+ private:
+  friend struct base::DefaultSingletonTraits<NickelAdBlockService>;
+
+  NickelAdBlockService();
+  ~NickelAdBlockService();
+
+  std::unique_ptr<NickelAdBlockEngine> engine_;
+  bool enabled_ = true;
+};
+
+}  // namespace adblock
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_SERVICE_H_
