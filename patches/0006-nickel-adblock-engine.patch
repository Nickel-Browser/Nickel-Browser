+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_service.cc
+
+#include "chrome/browser/nickel/adblock/nickel_adblock_service.h"
+
+#include "base/logging.h"
+#include "base/memory/singleton.h"
+#include "base/path_service.h"
+#include "base/files/file_util.h"
+#include "base/task/thread_pool.h"
+#include "chrome/common/chrome_paths.h"
+
+namespace nickel {
+namespace adblock {
+
+// static
+NickelAdBlockService* NickelAdBlockService::GetInstance() {
+  return base::Singleton<NickelAdBlockService>::get();
+}
+
+NickelAdBlockService::NickelAdBlockService()
+    : engine_(std::make_unique<NickelAdBlockEngine>()) {}
+
+NickelAdBlockService::~NickelAdBlockService() = default;
+
+void NickelAdBlockService::LoadDefaultFilterLists() {
+  // Bundled EasyList filter rules are compiled into resources.pak as a
+  // data resource.  In a real build this uses ui::ResourceBundle.
+  // For now we load from the app directory if present.
+  base::FilePath app_dir;
+  if (!base::PathService::Get(chrome::DIR_APP, &app_dir)) {
+    LOG(WARNING) << "NickelAdBlock: could not find app directory";
+    return;
+  }
+
+  base::FilePath filter_path = app_dir.AppendASCII("nickel_filters.txt");
+  std::string filter_text;
+  if (base::ReadFileToString(filter_path, &filter_text)) {
+    const size_t n = engine_->LoadRules(filter_text);
+    LOG(INFO) << "NickelAdBlock: loaded " << n << " rules from " << filter_path;
+  } else {
+    LOG(WARNING) << "NickelAdBlock: filter file not found at " << filter_path
+                 << "; ad blocking will be limited until next update";
+  }
+}
+
+void NickelAdBlockService::ReloadFilterLists(
+    const std::string& filter_list_text) {
+  engine_->Clear();
+  const size_t n = engine_->LoadRules(filter_list_text);
+  LOG(INFO) << "NickelAdBlock: reloaded " << n << " rules";
+}
+
+bool NickelAdBlockService::ShouldBlock(const GURL& request_url,
+                                       const GURL& document_url,
+                                       RequestType type) const {
+  if (!enabled_) return false;
+  return engine_->ShouldBlock(request_url, document_url, type).blocked;
+}
+
+void NickelAdBlockService::SetEnabled(bool enabled) {
+  enabled_ = enabled;
+  LOG(INFO) << "NickelAdBlock: " << (enabled ? "enabled" : "disabled");
+}
+
+bool NickelAdBlockService::IsEnabled() const {
+  return enabled_;
+}
+
+}  // namespace adblock
+}  // namespace nickel
