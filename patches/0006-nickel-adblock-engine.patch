+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_engine.h
+// Core ad-blocking filter engine for Nickel Browser.
+
+#ifndef CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_ENGINE_H_
+#define CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_ENGINE_H_
+
+#include <cstdint>
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/sequence_checker.h"
+#include "url/gurl.h"
+
+namespace nickel {
+namespace adblock {
+
+// Type of network request (mirrors Chromium's ResourceType).
+enum class RequestType : uint8_t {
+  kScript     = 0,
+  kImage      = 1,
+  kStylesheet = 2,
+  kXHR        = 3,
+  kFont       = 4,
+  kMedia      = 5,
+  kWebsocket  = 6,
+  kOther      = 7,
+};
+
+// Result of a filter engine evaluation.
+struct FilterResult {
+  bool blocked = false;
+  bool important = false;   // matched an !important rule (cannot be overridden)
+  std::string matched_rule; // the filter rule that matched (debug only)
+};
+
+// NickelAdBlockEngine evaluates filter lists against network requests.
+// All public methods must be called on the same sequence.
+class NickelAdBlockEngine {
+ public:
+  NickelAdBlockEngine();
+  ~NickelAdBlockEngine();
+
+  NickelAdBlockEngine(const NickelAdBlockEngine&) = delete;
+  NickelAdBlockEngine& operator=(const NickelAdBlockEngine&) = delete;
+
+  // Load filter rules from a raw EasyList/Adblock Plus format string.
+  // Returns the number of rules successfully parsed.
+  size_t LoadRules(const std::string& filter_list_text);
+
+  // Load rules from a serialised binary blob (produced by SerialiseRules()).
+  bool LoadBinary(const std::vector<uint8_t>& blob);
+
+  // Serialise current rule set to a compact binary blob for caching.
+  std::vector<uint8_t> SerialiseRules() const;
+
+  // Evaluate whether |request_url| (requested from |document_url|) should
+  // be blocked.
+  FilterResult ShouldBlock(const GURL& request_url,
+                           const GURL& document_url,
+                           RequestType type) const;
+
+  // Returns the number of loaded filter rules.
+  size_t RuleCount() const;
+
+  // Clear all loaded rules.
+  void Clear();
+
+ private:
+  struct Impl;
+  std::unique_ptr<Impl> impl_;
+
+  SEQUENCE_CHECKER(sequence_checker_);
+};
+
+}  // namespace adblock
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_ADBLOCK_NICKEL_ADBLOCK_ENGINE_H_
diff --git a/chrome/browser/nickel/adblock/nickel_adblock_engine.cc b/chrome/browser/nickel/adblock/nickel_adblock_engine.cc
new file mode 100644
