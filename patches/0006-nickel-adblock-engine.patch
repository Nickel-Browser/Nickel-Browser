+// Copyright (c) 2026 Nickel Browser Project
+// Use of this source code is governed by a BSD-3-Clause license.
+//
+// nickel_adblock_throttle.cc
+
+#include "chrome/browser/nickel/adblock/nickel_adblock_throttle.h"
+
+#include "chrome/browser/nickel/adblock/nickel_adblock_service.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "third_party/blink/public/common/loader/url_loader_throttle.h"
+
+namespace nickel {
+namespace adblock {
+
+NickelAdBlockThrottle::NickelAdBlockThrottle(const GURL& document_url)
+    : document_url_(document_url) {}
+
+NickelAdBlockThrottle::~NickelAdBlockThrottle() = default;
+
+void NickelAdBlockThrottle::WillStartRequest(
+    network::ResourceRequest* request,
+    bool* defer) {
+  *defer = false;
+
+  auto* service = NickelAdBlockService::GetInstance();
+  if (!service || !service->IsEnabled()) return;
+
+  // Map Chromium ResourceType to our RequestType.
+  RequestType type = RequestType::kOther;
+  if (request->destination ==
+      network::mojom::RequestDestination::kScript) {
+    type = RequestType::kScript;
+  } else if (request->destination ==
+             network::mojom::RequestDestination::kImage) {
+    type = RequestType::kImage;
+  } else if (request->destination ==
+             network::mojom::RequestDestination::kStyle) {
+    type = RequestType::kStylesheet;
+  } else if (request->destination ==
+             network::mojom::RequestDestination::kFont) {
+    type = RequestType::kFont;
+  }
+
+  if (service->ShouldBlock(request->url, document_url_, type)) {
+    VLOG(1) << "NickelAdBlock: blocked " << request->url;
+    delegate_->CancelWithError(net::ERR_BLOCKED_BY_CLIENT,
+                               "NickelAdBlock");
+  }
+}
+
+const char* NickelAdBlockThrottle::NameForLogging() {
+  return "NickelAdBlockThrottle";
+}
+
+}  // namespace adblock
+}  // namespace nickel
