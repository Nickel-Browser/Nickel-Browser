From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2026 00:00:00 +0000
Subject: [PATCH 11/17] nickel: wire-prefs — Register Nickel prefs in browser_prefs.cc

---
 chrome/browser/prefs/browser_prefs.cc | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/chrome/browser/prefs/browser_prefs.cc b/chrome/browser/prefs/browser_prefs.cc
index 47071e6..f9a1b2c 100644
--- a/chrome/browser/prefs/browser_prefs.cc
+++ b/chrome/browser/prefs/browser_prefs.cc
@@ -10,6 +10,8 @@
 #include "chrome/browser/prefs/browser_prefs.h"
 #include "components/prefs/pref_registry_simple.h"
 #include "components/prefs/pref_service.h"
+#include "chrome/browser/nickel/nickel_prefs.h"
+#include "chrome/browser/nickel/nickel_webrtc.h"

 namespace {

@@ -100,6 +102,10 @@ void RegisterLocalState(PrefRegistrySimple* registry) {
   metrics::MetricsReportingService::RegisterPrefs(registry);
   signin::RegisterLocalStatePrefs(registry);

+  // Nickel Browser local state
+  nickel::RegisterNickelLocalStatePrefs(registry);
 }

 void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry) {
@@ -150,5 +156,9 @@ void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry) {
   safe_browsing::RegisterProfilePrefs(registry);

+  // Nickel Browser profile-specific prefs
+  nickel::RegisterNickelProfilePrefs(registry);
+  nickel::RegisterNickelWebRTCPrefs(registry);
 }
