From: Nickel Browser Team <team@nickel-browser.org>
Date: Thu, 01 Jan 2026 00:00:00 +0000
Subject: [PATCH 01/10] nickel: branding — Deep product identity

---
 chrome/app/theme/chromium/BRANDING | 12 +++---
 chrome/app/chromium_strings.grd     | 10 ++++++++++
 chrome/app/generated_resources.grd  | 10 ++++++++++
 3 files changed, 26 insertions(+), 6 deletions(-)

diff --git a/chrome/app/theme/chromium/BRANDING b/chrome/app/theme/chromium/BRANDING
index aabbccdd..eeff0011 100644
--- a/chrome/app/theme/chromium/BRANDING
+++ b/chrome/app/theme/chromium/BRANDING
@@ -1,6 +1,6 @@
-COMPANY_FULLNAME=The Chromium Authors
-COMPANY_SHORTNAME=Chromium
-PRODUCT_FULLNAME=Chromium
-PRODUCT_SHORTNAME=Chromium
+COMPANY_FULLNAME=Nickel Browser Community
+COMPANY_SHORTNAME=Nickel
+PRODUCT_FULLNAME=Nickel Browser
+PRODUCT_SHORTNAME=Nickel
diff --git a/chrome/app/chromium_strings.grd b/chrome/app/chromium_strings.grd
index aabbccdd..eeff0011 100644
--- a/chrome/app/chromium_strings.grd
+++ b/chrome/app/chromium_strings.grd
@@ -10,6 +10,9 @@
+      <message name="IDS_PRODUCT_NAME" desc="The product name">
+        Nickel Browser
+      </message>
diff --git a/chrome/app/generated_resources.grd b/chrome/app/generated_resources.grd
index aabbccdd..eeff0011 100644
--- a/chrome/app/generated_resources.grd
+++ b/chrome/app/generated_resources.grd
@@ -10,6 +10,9 @@
+      <message name="IDS_ABOUT_PRODUCT_NAME" desc="Product name on the about page">
+        Nickel Browser
+      </message>
