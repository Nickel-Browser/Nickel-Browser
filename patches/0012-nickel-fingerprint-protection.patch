+
 namespace blink {
 
 namespace {
@@ -150,6 +154,67 @@ String WebGLRenderingContext::Vendor() const {
   if (!GetDrawingBuffer())
     return String();
   
+  // Nickel: Return spoofed vendor for fingerprint protection
