+#ifndef CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_CONFIG_H_
+#define CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_CONFIG_H_
+
+namespace nickel {
+
+// Nickel Browser Fingerprint Protection Configuration
+// All protections are ON by default for maximum privacy
+// Users can toggle via nickel://settings/privacy

+namespace fingerprint {
+
+// Canvas fingerprint protection
+constexpr bool kCanvasNoiseEnabled = true;
+constexpr double kCanvasNoiseLevel = 0.5;  // Pixel noise amount
+
+// WebGL fingerprint protection
+constexpr bool kWebGLSpoofEnabled = true;
+constexpr char kWebGLVendor[] = "Google Inc. (NVIDIA)";
+constexpr char kWebGLRenderer[] = "ANGLE (NVIDIA, NVIDIA GeForce GTX 1050 Direct3D11 vs_5_0 ps_5_0, D3D11)";
+
+// Audio fingerprint protection
+constexpr bool kAudioNoiseEnabled = true;
+constexpr double kAudioNoiseLevel = 0.001;
+
+// Client rects protection
+constexpr bool kClientRectsNoiseEnabled = true;
+constexpr double kClientRectsNoiseLevel = 0.1;
+
+// Font enumeration protection
+constexpr bool kFontEnumBlockEnabled = true;
+
+// Hardware API spoofing
+constexpr bool kHardwareSpoofEnabled = true;
+constexpr int kHardwareConcurrency = 4;
+constexpr int kDeviceMemoryGB = 8;
+
+// Screen resolution spoofing
+constexpr bool kScreenSpoofEnabled = true;
+constexpr int kScreenWidth = 1920;
+constexpr int kScreenHeight = 1080;
+constexpr int kScreenColorDepth = 24;
+
+// Battery API blocking
+constexpr bool kBatteryAPIBlockEnabled = true;
+
+// Sensor API blocking
+constexpr bool kSensorAPIBlockEnabled = true;
+
+// Keyboard/Mouse timing protection
+constexpr bool kInputTimingNormalizeEnabled = true;
+
+}  // namespace fingerprint
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_CONFIG_H_

diff --git a/chrome/browser/nickel/fingerprint/fingerprint_protection.cc b/chrome/browser/nickel/fingerprint/fingerprint_protection.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/chrome/browser/nickel/fingerprint/fingerprint_protection.cc
@@ -0,0 +1,345 @@
+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#include "chrome/browser/nickel/fingerprint/fingerprint_protection.h"
+
+#include <cmath>
+#include <random>
+
+#include "base/logging.h"
+#include "chrome/browser/nickel/fingerprint/fingerprint_config.h"
+#include "crypto/random.h"
+
+namespace nickel {
+
+namespace {
+
+// Per-session seed for deterministic noise
+uint64_t g_session_seed = 0;
+
+// Initialize session seed
+void InitializeSessionSeed() {
+  if (g_session_seed == 0) {
+    g_session_seed = crypto::RandUint64();
+    VLOG(1) << "Nickel Fingerprint: Session seed initialized";
+  }
+}
+
+// Generate deterministic noise for a given input
+double GenerateNoise(const std::string& input, double level) {
+  InitializeSessionSeed();
+  
+  // Combine input with session seed
+  std::hash<std::string> hasher;
+  size_t hash = hasher(input) ^ g_session_seed;
+  
+  // Convert to normalized noise value (-1 to 1)
+  double normalized = static_cast<double>(hash) / 
+                      static_cast<double>(std::numeric_limits<size_t>::max());
+  return (normalized * 2.0 - 1.0) * level;
+}
+
+// Get per-tab seed for randomization
+uint64_t GetTabSeed(int32_t tab_id) {
+  return g_session_seed ^ static_cast<uint64_t>(tab_id);
+}
+
+}  // namespace
+
+// static
+FingerprintProtection* FingerprintProtection::GetInstance() {
+  static base::NoDestructor<FingerprintProtection> instance;
+  return instance.get();
+}
+
+FingerprintProtection::FingerprintProtection() {
+  InitializeSessionSeed();
+}
+
+FingerprintProtection::~FingerprintProtection() = default;
+
+void FingerprintProtection::Initialize() {
+  VLOG(1) << "Nickel Fingerprint Protection: Initializing...";
+  
+  // Log enabled protections
+  if (fingerprint::kCanvasNoiseEnabled) {
+    VLOG(1) << "  - Canvas noise injection: ENABLED";
+  }
+  if (fingerprint::kWebGLSpoofEnabled) {
+    VLOG(1) << "  - WebGL spoofing: ENABLED";
+  }
+  if (fingerprint::kAudioNoiseEnabled) {
+    VLOG(1) << "  - Audio noise: ENABLED";
+  }
+  if (fingerprint::kClientRectsNoiseEnabled) {
+    VLOG(1) << "  - Client rects noise: ENABLED";
+  }
+  if (fingerprint::kFontEnumBlockEnabled) {
+    VLOG(1) << "  - Font enumeration block: ENABLED";
+  }
+  if (fingerprint::kHardwareSpoofEnabled) {
+    VLOG(1) << "  - Hardware spoofing: ENABLED";
+  }
+  if (fingerprint::kScreenSpoofEnabled) {
+    VLOG(1) << "  - Screen spoofing: ENABLED";
+  }
+  if (fingerprint::kBatteryAPIBlockEnabled) {
+    VLOG(1) << "  - Battery API block: ENABLED";
+  }
+  if (fingerprint::kSensorAPIBlockEnabled) {
+    VLOG(1) << "  - Sensor API block: ENABLED";
+  }
+}
+
+// Canvas Protection
+void FingerprintProtection::ProtectCanvasData(
+    const std::string& context_id,
+    std::vector<uint8_t>* data,
+    int width,
+    int height) {
+  if (!fingerprint::kCanvasNoiseEnabled || !data || data->empty()) {
+    return;
+  }
+  
+  // Add subtle noise to canvas pixel data
+  for (size_t i = 0; i < data->size(); ++i) {
+    std::string key = context_id + std::to_string(i);
+    double noise = GenerateNoise(key, fingerprint::kCanvasNoiseLevel);
+    
+    int value = static_cast<int>((*data)[i]) + static_cast<int>(noise);
+    (*data)[i] = static_cast<uint8_t>(std::clamp(value, 0, 255));
+  }
+}
+
+std::string FingerprintProtection::ProtectCanvasDataURL(
+    const std::string& context_id,
+    const std::string& data_url) {
+  if (!fingerprint::kCanvasNoiseEnabled) {
+    return data_url;
+  }
+  
+  // For data URLs, we can't easily modify the encoded data
+  // The actual protection happens in ProtectCanvasData before encoding
+  return data_url;
+}
+
+// WebGL Protection
+std::string FingerprintProtection::GetSpoofedWebGLVendor() {
+  if (fingerprint::kWebGLSpoofEnabled) {
+    return fingerprint::kWebGLVendor;
+  }
+  return "";
+}
+
+std::string FingerprintProtection::GetSpoofedWebGLRenderer() {
+  if (fingerprint::kWebGLSpoofEnabled) {
+    return fingerprint::kWebGLRenderer;
+  }
+  return "";
+}
+
+// Audio Protection
+void FingerprintProtection::ProtectAudioData(
+    const std::string& context_id,
+    float* data,
+    size_t length) {
+  if (!fingerprint::kAudioNoiseEnabled || !data || length == 0) {
+    return;
+  }
+  
+  // Add imperceptible noise to audio data
+  for (size_t i = 0; i < length; ++i) {
+    std::string key = context_id + std::to_string(i);
+    double noise = GenerateNoise(key, fingerprint::kAudioNoiseLevel);
+    data[i] += static_cast<float>(noise);
+  }
+}
+
+// Client Rects Protection
+float FingerprintProtection::ProtectClientRect(
+    const std::string& element_id,
+    float value) {
+  if (!fingerprint::kClientRectsNoiseEnabled) {
+    return value;
+  }
+  
+  double noise = GenerateNoise(element_id, fingerprint::kClientRectsNoiseLevel);
+  return value + static_cast<float>(noise);
+}
+
+// Font Protection
+bool FingerprintProtection::ShouldBlockFontEnumeration() {
+  return fingerprint::kFontEnumBlockEnabled;
+}
+
+std::vector<std::string> FingerprintProtection::GetAllowedFontList() {
+  // Return a minimal, generic font list
+  return {
+    "Arial",
+    "Courier New",
+    "Georgia",
+    "Times New Roman",
+    "Verdana"
+  };
+}
+
+// Hardware Protection
+int FingerprintProtection::GetSpoofedHardwareConcurrency() {
+  if (fingerprint::kHardwareSpoofEnabled) {
+    return fingerprint::kHardwareConcurrency;
+  }
+  return -1;  // Use actual value
+}
+
+int FingerprintProtection::GetSpoofedDeviceMemory() {
+  if (fingerprint::kHardwareSpoofEnabled) {
+    return fingerprint::kDeviceMemoryGB;
+  }
+  return -1;  // Use actual value
+}
+
+// Screen Protection
+gfx::Size FingerprintProtection::GetSpoofedScreenSize() {
+  if (fingerprint::kScreenSpoofEnabled) {
+    return gfx::Size(fingerprint::kScreenWidth, fingerprint::kScreenHeight);
+  }
+  return gfx::Size();  // Use actual value
+}
+
+int FingerprintProtection::GetSpoofedColorDepth() {
+  if (fingerprint::kScreenSpoofEnabled) {
+    return fingerprint::kScreenColorDepth;
+  }
+  return -1;  // Use actual value
+}
+
+// Battery Protection
+bool FingerprintProtection::ShouldBlockBatteryAPI() {
+  return fingerprint::kBatteryAPIBlockEnabled;
+}
+
+// Sensor Protection
+bool FingerprintProtection::ShouldBlockSensorAPI(const std::string& sensor_type) {
+  return fingerprint::kSensorAPIBlockEnabled;
+}
+
+// Input Timing Protection
+bool FingerprintProtection::ShouldNormalizeInputTiming() {
+  return fingerprint::kInputTimingNormalizeEnabled;
+}
+
+int64_t FingerprintProtection::NormalizeTimestamp(int64_t timestamp) {
+  if (!fingerprint::kInputTimingNormalizeEnabled) {
+    return timestamp;
+  }
+  
+  // Round to nearest 10ms to reduce timing precision
+  return (timestamp / 10000) * 10000;
+}
+
+// Per-tab randomization
+uint64_t FingerprintProtection::GetTabRandomSeed(int32_t tab_id) {
+  return GetTabSeed(tab_id);
+}
+
+}  // namespace nickel

