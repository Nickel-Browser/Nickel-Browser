+// Copyright (c) 2025 Nickel Browser Project
+// Use of this source code is governed by a GPLv3 license.
+
+#ifndef CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_PROTECTION_H_
+#define CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_PROTECTION_H_
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+#include "base/no_destructor.h"
+#include "ui/gfx/geometry/size.h"
+
+namespace nickel {
+
+// Main class for fingerprint protection
+class FingerprintProtection {
+ public:
+  // Returns the singleton instance
+  static FingerprintProtection* GetInstance();
+
+  // Initialize fingerprint protection
+  void Initialize();
+
+  // Canvas protection
+  void ProtectCanvasData(const std::string& context_id,
+                         std::vector<uint8_t>* data,
+                         int width,
+                         int height);
+  std::string ProtectCanvasDataURL(const std::string& context_id,
+                                   const std::string& data_url);
+
+  // WebGL protection
+  std::string GetSpoofedWebGLVendor();
+  std::string GetSpoofedWebGLRenderer();
+
+  // Audio protection
+  void ProtectAudioData(const std::string& context_id,
+                        float* data,
+                        size_t length);
+
+  // Client rects protection
+  float ProtectClientRect(const std::string& element_id, float value);
+
+  // Font protection
+  bool ShouldBlockFontEnumeration();
+  std::vector<std::string> GetAllowedFontList();
+
+  // Hardware protection
+  int GetSpoofedHardwareConcurrency();
+  int GetSpoofedDeviceMemory();
+
+  // Screen protection
+  gfx::Size GetSpoofedScreenSize();
+  int GetSpoofedColorDepth();
+
+  // Battery protection
+  bool ShouldBlockBatteryAPI();
+
+  // Sensor protection
+  bool ShouldBlockSensorAPI(const std::string& sensor_type);
+
+  // Input timing protection
+  bool ShouldNormalizeInputTiming();
+  int64_t NormalizeTimestamp(int64_t timestamp);
+
+  // Per-tab randomization
+  uint64_t GetTabRandomSeed(int32_t tab_id);
+
+ private:
+  FingerprintProtection();
+  ~FingerprintProtection();
+  
+  friend class base::NoDestructor<FingerprintProtection>;
+};
+
+}  // namespace nickel
+
+#endif  // CHROME_BROWSER_NICKEL_FINGERPRINT_FINGERPRINT_PROTECTION_H_

