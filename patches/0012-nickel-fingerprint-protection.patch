diff --git a/third_party/blink/renderer/modules/webaudio/audio_buffer.cc b/third_party/blink/renderer/modules/webaudio/audio_buffer.cc
index 1234567..abcdefg 100644
--- a/third_party/blink/renderer/modules/webaudio/audio_buffer.cc
+++ b/third_party/blink/renderer/modules/webaudio/audio_buffer.cc
@@ -25,6 +25,10 @@
 #include "third_party/blink/renderer/platform/wtf/text/string_builder.h"
 #include "third_party/blink/renderer/platform/wtf/vector.h"
 
+// Nickel: Fingerprint protection
+#include "chrome/browser/nickel/fingerprint/fingerprint_protection.h"
+#include "chrome/browser/nickel/fingerprint/fingerprint_config.h"
+
 namespace blink {
 
 namespace {
@@ -200,6 +204,47 @@ AudioBuffer::AudioBuffer(AudioBus* bus)
   DCHECK(!bus_->IsFirstTimeDynamicsCompressor());
 }
 
+// Nickel: Protect audio data from fingerprinting
+void AudioBuffer::ProtectAudioFingerprint() {
+  if (!nickel::fingerprint::kAudioNoiseEnabled) {
+    return;
+  }
+  
+  auto* protection = nickel::FingerprintProtection::GetInstance();
+  if (!protection) {
+    return;
+  }
+  
+  // Generate context ID from buffer properties
+  std::string context_id = std::to_string(numberOfChannels()) + "_" +
+                           std::to_string(length()) + "_" +
+                           std::to_string(sampleRate());
+  
+  // Apply noise to each channel
+  for (uint32_t channel = 0; channel < numberOfChannels(); ++channel) {
+    float* channel_data = getChannelData(channel)->Data();
+    protection->ProtectAudioData(context_id + "_" + std::to_string(channel),
+                                 channel_data, length());
+  }
+}
+
 NotShared<DomFloat32Array> AudioBuffer::getChannelData(
     unsigned channel_index,
     ExceptionState& exception_state) {
@@ -210,6 +255,10 @@ NotShared<DomFloat32Array> AudioBuffer::getChannelData(
     return NotShared<DomFloat32Array>(nullptr);
   }
   
+  // Nickel: Apply fingerprint protection before returning data
+  if (nickel::fingerprint::kAudioNoiseEnabled) {
+    ProtectAudioFingerprint();
+  }
+  
   return NotShared<DomFloat32Array>(channels_[channel_index]);
 }
 
